{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning"
    },
    "File": {
      "Path": "Logs/app_log.txt",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 14,
      "FileSizeLimitBytes": 10000000
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Data Source=integracao_controlid.db"
  },

  "Session": {
    "IdleTimeout": 30,
    "CookieName": ".IntegracaoControlID.Session",
    "CookieHttpOnly": true,
    "CookieSecure": "Always"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithProcessId" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app_log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 10000000,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  "ControlIDApi": {
    "DefaultDeviceUrl": "http://192.168.1.100:8080", // Ajuste conforme seu cenário de teste
    "DefaultUsername": "admin",
    "DefaultPassword": "admin",
    "ConnectionTimeoutSeconds": 10
  },

  "Security": {
    "PasswordSaltLength": 16,
    "TokenLength": 32
  },

  "CallbackSecurity": {
    "MaxBodyBytes": 1048576,
    "RequireSharedKey": false,
    "SharedKeyHeaderName": "X-ControlID-Callback-Key",
    "SharedKey": "",
    "AllowLoopback": true,
    "AllowedRemoteIps": []
  }
}
