{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning"
    },
    "File": {
      "Path": "Logs/app_log.txt",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 14,
      "FileSizeLimitBytes": 10000000
    }
  },
  "AllowedHosts": "*",

  "Host": {
    "ShutdownTimeoutSeconds": 30
  },

  "ForwardedHeaders": {
    "Enabled": false,
    "ForwardLimit": 1,
    "KnownProxies": []
  },

  "ConnectionStrings": {
    "DefaultConnection": "Data Source=integracao_controlid.db"
  },

  "Session": {
    "IdleTimeout": 30,
    "CookieName": ".IntegracaoControlID.Session",
    "CookieHttpOnly": true,
    "CookieSecure": "Always"
  },

  "Auth": {
    "IdleTimeoutMinutes": 60,
    "CookieName": ".IntegracaoControlID.Auth",
    "RateLimit": {
      "PermitLimit": 10,
      "WindowSeconds": 300
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithProcessId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] [corr:{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app_log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 10000000,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] [corr:{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  "ControlIDApi": {
    "DefaultDeviceUrl": "", // SECURITY: nunca versione enderecos internos padrao; informe manualmente ou via User Secrets/env vars.
    "DefaultUsername": "", // SECURITY: nunca preencha usuario padrao na UI; use input manual, User Secrets ou variaveis de ambiente.
    "DefaultPassword": "", // SECURITY: nunca versione credenciais reais; use input manual, User Secrets ou variaveis de ambiente.
    "ConnectionTimeoutSeconds": 10,
    "RequireAllowedDeviceHosts": false, // SECURITY: em ambientes fora de Development, habilite e preencha AllowedDeviceHosts.
    "AllowedDeviceHosts": [],
    "CircuitBreaker": {
      "Enabled": true,
      "FailureThreshold": 5,
      "BreakDurationSeconds": 30
    }
  },

  "OpenApi": {
    "Enabled": false
  },

  "Observability": {
    "Metrics": {
      "Enabled": true,
      "AllowAnonymous": false
    }
  },

  "Security": {
    "PasswordSaltLength": 16,
    "TokenLength": 32,
    "InteractiveRateLimit": {
      "PermitLimit": 600,
      "WindowSeconds": 60
    }
  },

  "CallbackSecurity": {
    "MaxBodyBytes": 1048576,
    "RequireSharedKey": false, // SECURITY: habilite em ambientes expostos ou integracoes fora de loopback/local.
    "SharedKeyHeaderName": "X-ControlID-Callback-Key",
    "SharedKey": "",
    "AllowLoopback": true,
    "AllowedRemoteIps": [],
    "RequireSignedRequests": false, // SECURITY: obrigatorio fora de Development; assina method/path/query/timestamp/nonce/bodyHash com HMAC-SHA256.
    "SignatureHeaderName": "X-ControlID-Signature",
    "TimestampHeaderName": "X-ControlID-Timestamp",
    "NonceHeaderName": "X-ControlID-Nonce",
    "MaxClockSkewSeconds": 300,
    "NonceTtlSeconds": 600,
    "RateLimit": {
      "PermitLimit": 120,
      "WindowSeconds": 60
    }
  }
}


