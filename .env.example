# Copy this file to .env for local container execution.
# Replace every placeholder before running with ASPNETCORE_ENVIRONMENT=Staging or Production.

APP_PORT=8080
ASPNETCORE_ENVIRONMENT=Production
AllowedHosts=poc.example.internal
Host__ShutdownTimeoutSeconds=30
ConnectionStrings__DefaultConnection=Data Source=/app/data/integracao_controlid.db

# Reverse proxy support is opt-in. Keep disabled unless the app is behind a trusted proxy.
ForwardedHeaders__Enabled=false
ForwardedHeaders__ForwardLimit=1
ForwardedHeaders__KnownProxies__0=

OpenApi__Enabled=false
Observability__Metrics__Enabled=true
Observability__Metrics__AllowAnonymous=false

ControlIDApi__DefaultDeviceUrl=http://controlid-device.example.internal:8080
ControlIDApi__DefaultUsername=
ControlIDApi__DefaultPassword=
ControlIDApi__ConnectionTimeoutSeconds=10
ControlIDApi__RequireAllowedDeviceHosts=true
ControlIDApi__AllowedDeviceHosts__0=controlid-device.example.internal
ControlIDApi__CircuitBreaker__Enabled=true
ControlIDApi__CircuitBreaker__FailureThreshold=5
ControlIDApi__CircuitBreaker__BreakDurationSeconds=30

CallbackSecurity__MaxBodyBytes=1048576
CallbackSecurity__RequireSharedKey=true
CallbackSecurity__SharedKey=replace-with-at-least-32-random-characters
CallbackSecurity__RequireSignedRequests=true
CallbackSecurity__AllowLoopback=false
CallbackSecurity__AllowedRemoteIps__0=
