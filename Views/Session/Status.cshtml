@model Integracao.ControlID.PoC.ViewModels.Session.SessionStatusViewModel
@{
    ViewData["Title"] = "Status da Sessão";
}

<div class="container mt-5">
    <h2>Status da Sessão</h2>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-@(Model.StatusType ?? "info")">@Model.StatusMessage</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Dispositivo</dt>
                <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.DeviceAddress) ? Model.DeviceAddress : "-")</dd>

                <dt class="col-sm-3">Sessão</dt>
                <dd class="col-sm-9"><code>@(!string.IsNullOrWhiteSpace(Model.SessionString) ? Model.SessionString : "-")</code></dd>
            </dl>

            <form asp-action="Validate" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">Validar Sessão</button>
            </form>
            <form asp-action="Clear" method="post" class="d-inline ms-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">Limpar Sessão Local</button>
            </form>
        </div>
    </div>
</div>
