@model Integracao.ControlID.PoC.Models.Database.SessionLocal
@{
    ViewData["Title"] = "Encerrar sessão";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Encerrar sessão",
        Description = "Confirme a remoção desta sessão persistida antes de limpar o contexto local usado pela PoC para comunicação com o equipamento.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar para sessões", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <section class="detail-card detail-card--danger app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>Usuário</span><strong>@Model.Username</strong></div>
            <div class="entity-overview__item"><span>Equipamento</span><strong>@Model.DeviceName</strong></div>
            <div class="entity-overview__item"><span>Sessão</span><strong>@SecurityTextHelper.MaskSensitiveValue(Model.SessionString)</strong></div>
        </div>
        <div class="app-note">Essa ação remove a sessão persistida localmente e pode exigir nova autenticação para os fluxos protegidos do equipamento.</div>
    </section>

    <section class="app-surface-card app-stack">
        <div class="alert alert-warning mb-0">
            Deseja realmente encerrar a sessão do usuário <strong>@Model.Username</strong> no equipamento <strong>@Model.DeviceName</strong>?
        </div>

        <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="form-actions">
            <button type="submit" class="btn btn-danger">Sim, encerrar sessão</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </section>
</div>
