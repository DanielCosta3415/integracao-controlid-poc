@model Integracao.ControlID.PoC.ViewModels.Hardware.DoorStateViewModel
@{
    ViewData["Title"] = "Estado das Portas";
}

<div class="container mt-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1">Estado das Portas</h2>
            <p class="text-muted mb-0">Consulta o endpoint oficial `door_state` com ou sem filtro por porta.</p>
        </div>
        <a asp-action="Status" class="btn btn-outline-secondary">Voltar para Hardware</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="DoorState" method="get" autocomplete="off" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="DoorNumber" class="form-label"></label>
                    <input asp-for="DoorNumber" class="form-control" />
                    <span asp-validation-for="DoorNumber" class="text-danger"></span>
                </div>
                <div class="col-md-8 d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">Consultar</button>
                    <a asp-action="DoorState" class="btn btn-outline-secondary">Consultar Todas</a>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Summary) || !string.IsNullOrWhiteSpace(Model.ResponseJson))
    {
        <div class="card shadow-sm">
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.Summary))
                {
                    <div class="alert alert-info">@Model.Summary</div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ResponseJson))
                {
                    <h5>Resposta Oficial</h5>
                    <pre class="small mb-0">@Model.ResponseJson</pre>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
