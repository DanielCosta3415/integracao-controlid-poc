@model Integracao.ControlID.PoC.ViewModels.Hardware.HardwareStatusViewModel
@{
    ViewData["Title"] = "Status do hardware";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Status do hardware",
        Description = "Consulta oficial do hardware com atalhos para GPIO, portas, saída remota e validação biométrica.",
        BadgeText = "Leitura operacional",
        BadgeTone = "info",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Estado das portas", Href = Url.Action("DoorState")!, ButtonClass = "btn btn-outline-info" }, new PageHeaderActionViewModel { Label = "GPIO", Href = Url.Action("Gpio")!, ButtonClass = "btn btn-outline-secondary" }, new PageHeaderActionViewModel { Label = "Abrir saída", Href = Url.Action("RelayAction")!, ButtonClass = "btn btn-primary" }, new PageHeaderActionViewModel { Label = "Validar biometria", Href = Url.Action("ValidateBiometry")!, ButtonClass = "btn btn-outline-primary" } }
    };
    var rawPanel = Model.HardwareStatus != null && !string.IsNullOrWhiteSpace(Model.HardwareStatus.RawJson) ? new RawResponsePanelViewModel { Title = "Resposta oficial", Description = "JSON bruto retornado pelo status de hardware.", Content = Model.HardwareStatus.RawJson, PanelId = "hardware-status-raw", BadgeText = "Hardware", BadgeTone = "neutral" } : null;
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" />@if (TempData["StatusMessage"] is string statusMessage){<div class="alert alert-@(TempData["StatusType"] ?? "info")">@statusMessage</div>}@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)){<div class="alert alert-danger">@Model.ErrorMessage</div>}@if (Model.HardwareStatus != null){<section class="detail-card app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>Status</span><strong>@Model.HardwareStatus.Status</strong></div><div class="entity-overview__item"><span>Serial</span><strong>@Model.HardwareStatus.Serial</strong></div><div class="entity-overview__item"><span>IP</span><strong>@Model.HardwareStatus.IpAddress</strong></div><div class="entity-overview__item"><span>Firmware</span><strong>@Model.HardwareStatus.Firmware</strong></div></div></section><section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Metadados do equipamento</strong><p>Visão consolidada dos principais indicadores retornados pelo status oficial de hardware.</p></div></div><dl class="row"><dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.HardwareStatus.Status</dd><dt class="col-sm-3">Serial</dt><dd class="col-sm-9">@Model.HardwareStatus.Serial</dd><dt class="col-sm-3">Device ID</dt><dd class="col-sm-9">@Model.HardwareStatus.DeviceId</dd><dt class="col-sm-3">IP</dt><dd class="col-sm-9">@Model.HardwareStatus.IpAddress</dd><dt class="col-sm-3">Firmware</dt><dd class="col-sm-9">@Model.HardwareStatus.Firmware</dd><dt class="col-sm-3">Temperatura</dt><dd class="col-sm-9">@Model.HardwareStatus.Temperature</dd><dt class="col-sm-3">Porta aberta</dt><dd class="col-sm-9">@(Model.HardwareStatus.DoorOpen.HasValue ? (Model.HardwareStatus.DoorOpen.Value ? "Sim" : "Não") : "-")</dd><dt class="col-sm-3">Violação (tamper)</dt><dd class="col-sm-9">@(Model.HardwareStatus.Tamper.HasValue ? (Model.HardwareStatus.Tamper.Value ? "Sim" : "Não") : "-")</dd><dt class="col-sm-3">Tensão de alimentação</dt><dd class="col-sm-9">@Model.HardwareStatus.PowerVoltage</dd><dt class="col-sm-3">Sensores</dt><dd class="col-sm-9">@Model.HardwareStatus.SensorsInfo</dd><dt class="col-sm-3">Data da consulta</dt><dd class="col-sm-9">@(Model.HardwareStatus.RetrievedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd></dl></section><section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Ações de hardware</strong><p>Use estes atalhos para avançar para leituras complementares ou atualizar o cache local de LEDs.</p></div></div><div class="detail-actions"><a asp-action="DoorState" class="btn btn-outline-info">Consultar estado das portas</a><form asp-action="RereadLeds" method="post" class="app-inline-form"><button type="submit" class="btn btn-outline-warning">Recarregar LEDs</button></form></div></section>@if (rawPanel != null){<partial name="_RawResponsePanel" model="rawPanel" />}}else{<div class="alert alert-danger">Não foi possível obter o status do hardware.</div>}</div>
