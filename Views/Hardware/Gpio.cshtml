@model Integracao.ControlID.PoC.ViewModels.Hardware.GpioStateViewModel
@{
    ViewData["Title"] = "Estado dos GPIOs";
}

<div class="container mt-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1">Estado dos GPIOs</h2>
            <p class="text-muted mb-0">Consulta consolidada dos GPIOs oficiais expostos pelo equipamento.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="DoorState" class="btn btn-outline-info">Estado das Portas</a>
            <a asp-action="RelayAction" class="btn btn-primary">Abrir Saída</a>
        </div>
    </div>
    @if (Model.GpioState != null)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Entradas Digitais</h5>
                <ul>
                    @if (Model.GpioState.Inputs != null)
                    {
                        foreach (var input in Model.GpioState.Inputs)
                        {
                            <li>@input.Key: <b>@(input.Value ? "Ativo" : "Inativo")</b></li>
                        }
                    }
                    else
                    {
                        <li>Nenhuma entrada encontrada.</li>
                    }
                </ul>
                <h5 class="mt-3">Saídas Digitais</h5>
                <ul>
                    @if (Model.GpioState.Outputs != null)
                    {
                        foreach (var output in Model.GpioState.Outputs)
                        {
                            <li>@output.Key: <b>@(output.Value ? "Ativo" : "Inativo")</b></li>
                        }
                    }
                    else
                    {
                        <li>Nenhuma saída encontrada.</li>
                    }
                </ul>
                <dl class="row mt-3">
                    <dt class="col-sm-3">Data da Consulta</dt>
                    <dd class="col-sm-9">@(Model.GpioState.RetrievedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
                    <dt class="col-sm-3">Info</dt>
                    <dd class="col-sm-9">@Model.GpioState.Info</dd>
                </dl>
                @if (!string.IsNullOrWhiteSpace(Model.GpioState.RawJson))
                {
                    <hr />
                    <h5>Resposta Oficial Consolidada</h5>
                    <pre class="small mb-0">@Model.GpioState.RawJson</pre>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">Não foi possível obter o estado dos GPIOs.</div>
    }
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Status" class="btn btn-secondary">Voltar para Status do Hardware</a>
        <a asp-action="RelayAction" class="btn btn-primary">Abrir Saída</a>
    </div>
</div>
