@model Integracao.ControlID.PoC.ViewModels.Hardware.GpioStateViewModel
@{
    ViewData["Title"] = "Estado dos GPIOs";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Estado dos GPIOs",
        Description = "Consulta consolidada das entradas e saídas digitais expostas oficialmente pelo equipamento.",
        BadgeText = "Leitura operacional",
        BadgeTone = "info",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Estado das portas", Href = Url.Action("DoorState")!, ButtonClass = "btn btn-outline-info" }, new PageHeaderActionViewModel { Label = "Abrir saída", Href = Url.Action("RelayAction")!, ButtonClass = "btn btn-primary" } }
    };
    var rawPanel = Model.GpioState != null && !string.IsNullOrWhiteSpace(Model.GpioState.RawJson) ? new RawResponsePanelViewModel { Title = "Resposta oficial consolidada", Description = "JSON bruto retornado para os estados de GPIO.", Content = Model.GpioState.RawJson, PanelId = "hardware-gpio-raw", BadgeText = "GPIO", BadgeTone = "neutral" } : null;
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" />@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)){<div class="alert alert-danger">@Model.ErrorMessage</div>}@if (Model.GpioState != null){<section class="app-grid-two app-grid-two--main"><section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Entradas digitais</strong><p>Estados atuais das entradas lidas no equipamento.</p></div></div>@if (Model.GpioState.Inputs != null && Model.GpioState.Inputs.Any()){<div class="app-mini-grid">@foreach (var input in Model.GpioState.Inputs){<div class="app-mini-stat"><span>@input.Key</span><strong>@(input.Value ? "Ativo" : "Inativo")</strong></div>}</div>}else{<div class="app-empty">Nenhuma entrada encontrada.</div>}</section><section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Saídas digitais</strong><p>Estados atuais das saídas lidas no equipamento.</p></div></div>@if (Model.GpioState.Outputs != null && Model.GpioState.Outputs.Any()){<div class="app-mini-grid">@foreach (var output in Model.GpioState.Outputs){<div class="app-mini-stat"><span>@output.Key</span><strong>@(output.Value ? "Ativo" : "Inativo")</strong></div>}</div>}else{<div class="app-empty">Nenhuma saída encontrada.</div>}</section></section><section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Metadados da leitura</strong><p>Contexto adicional retornado junto com o estado consolidado dos GPIOs.</p></div></div><dl class="row"><dt class="col-sm-3">Data da consulta</dt><dd class="col-sm-9">@(Model.GpioState.RetrievedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd><dt class="col-sm-3">Info</dt><dd class="col-sm-9">@Model.GpioState.Info</dd></dl></section>@if (rawPanel != null){<partial name="_RawResponsePanel" model="rawPanel" />}}else{<div class="alert alert-danger">Não foi possível obter o estado dos GPIOs.</div>}</div>
