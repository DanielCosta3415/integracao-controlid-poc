@model Integracao.ControlID.PoC.ViewModels.Hardware.RelayActionViewModel
@{
    ViewData["Title"] = "Acionar relé";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Abrir saída remota",
        Description = "Dispare uma abertura temporizada da saída configurada no equipamento usando o fluxo oficial de ação remota.",
        BadgeText = "Comando operacional",
        BadgeTone = "warning",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para hardware", Href = Url.Action("Status")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>Endpoint</span><strong>execute_actions</strong></div><div class="entity-overview__item"><span>Ação</span><strong>door</strong></div><div class="entity-overview__item"><span>Porta</span><strong>@Model.DoorNumber</strong></div></div><div class="app-note">Essa operação dispara uma abertura temporizada da saída configurada no equipamento.</div></section><section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Parâmetros do acionamento</strong><p>Informe a porta desejada e confirme o comando antes de executá-lo no equipamento.</p></div></div><form asp-action="RelayAction" method="post" autocomplete="off" class="form-section"><div class="app-form-grid"><div><label asp-for="DoorNumber" class="form-label"></label><input asp-for="DoorNumber" class="form-control" min="1" /><span asp-validation-for="DoorNumber" class="text-danger"></span></div></div><div class="form-actions"><button type="submit" class="btn btn-warning">Acionar saída</button><a asp-action="Status" class="btn btn-outline-secondary">Cancelar</a></div></form></section></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
