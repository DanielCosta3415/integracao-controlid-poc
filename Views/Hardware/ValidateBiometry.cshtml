@model Integracao.ControlID.PoC.ViewModels.Hardware.BiometryValidationViewModel
@{
    ViewData["Title"] = "Validar biometria";

    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Validar biometria",
        Description = "Envie um arquivo binário para o endpoint oficial `is_valid_biometry` e valide rapidamente o retorno do equipamento.",
        BadgeText = "Ferramenta técnica",
        BadgeTone = "info",
        Actions = new[]
        {
            new PageHeaderActionViewModel
            {
                Label = "Voltar para hardware",
                Href = Url.Action("Status")!,
                ButtonClass = "btn btn-outline-secondary"
            }
        }
    };

    var responsePanel = string.IsNullOrWhiteSpace(Model.ResponseJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Resposta oficial",
            Description = "JSON bruto retornado por `is_valid_biometry`.",
            Content = Model.ResponseJson,
            PanelId = "hardware-validate-biometry-response",
            BadgeText = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "Retorno técnico" : Model.ResultStatusType,
            BadgeTone = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "neutral" : Model.ResultStatusType
        };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">@Model.ResultMessage</div>
    }

    <section class="app-grid-two app-grid-two--main">
        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Arquivo biométrico</strong>
                    <p>Selecione o arquivo binário que será enviado ao endpoint oficial para validação.</p>
                </div>
            </div>

            <form asp-action="ValidateBiometry" method="post" enctype="multipart/form-data" autocomplete="off" class="form-section">
                <div class="app-upload-field">
                    <label asp-for="BiometryFile" class="form-label"></label>
                    <input asp-for="BiometryFile" class="form-control" type="file" />
                    <p class="app-upload-field__hint">Use este fluxo para verificar previamente se o binário já está em um formato aceito antes de tentar cadastro ou comparação.</p>
                    <div class="app-upload-field__meta">
                        <span class="product-specific-token">Entrada binária</span>
                        <span class="product-specific-token">Fluxo: is_valid_biometry</span>
                    </div>
                    <span asp-validation-for="BiometryFile" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Validar biometria</button>
                </div>
            </form>
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Orientação operacional</strong>
                    <p>Use esse fluxo para confirmar rapidamente a integridade do arquivo antes de seguir para rotinas mais custosas de biometria.</p>
                </div>
            </div>

            <div class="app-note">O retorno técnico completo permanece disponível no painel bruto abaixo para diagnóstico e registro de evidências.</div>
        </section>
    </section>

    @if (responsePanel != null)
    {
        <partial name="_RawResponsePanel" model="responsePanel" />
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

