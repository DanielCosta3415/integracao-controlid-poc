@model Integracao.ControlID.PoC.ViewModels.Cards.CardViewModel
@{
    ViewData["Title"] = "Detalhes do Cartão";
}

<div class="container mt-5">
    <h2>Detalhes do Cartão</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.Id</dd>
                <dt class="col-sm-3">Usuário</dt>
                <dd class="col-sm-9">@Model.UserId</dd>
                <dt class="col-sm-3">Valor</dt>
                <dd class="col-sm-9">@Model.Value</dd>
                <dt class="col-sm-3">Tipo</dt>
                <dd class="col-sm-9">@Model.Type</dd>
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>
                <dt class="col-sm-3">Validade Início</dt>
                <dd class="col-sm-9">@Model.BeginTime?.ToString("dd/MM/yyyy HH:mm") ?? "-"</dd>
                <dt class="col-sm-3">Validade Fim</dt>
                <dd class="col-sm-9">@Model.EndTime?.ToString("dd/MM/yyyy HH:mm") ?? "-"</dd>
                <dt class="col-sm-3">Criado em</dt>
                <dd class="col-sm-9">@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-"</dd>
            </dl>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">Voltar</a>
        </div>
    </div>
</div>