@model Integracao.ControlID.PoC.ViewModels.Users.UserEditViewModel
@{
    ViewData["Title"] = "Editar usuário";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Editar usuário",
        Description = "Atualize os dados oficiais do usuário, status e janela de validade com o mesmo padrão visual aplicado aos demais workspaces da PoC.",
        BadgeText = "Edição",
        BadgeTone = "warning",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para usuários", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div><div class="entity-overview__item"><span>Nome</span><strong>@(string.IsNullOrWhiteSpace(Model.Name) ? "Não definido" : Model.Name)</strong></div><div class="entity-overview__item"><span>Matrícula</span><strong>@(string.IsNullOrWhiteSpace(Model.Registration) ? "Não definida" : Model.Registration)</strong></div></div></section><section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Dados do usuário</strong><p>Revise as informações pessoais, status e credencial opcional antes de salvar as alterações.</p></div></div><form asp-action="Edit" method="post" autocomplete="off" class="form-section"><input type="hidden" asp-for="Id" /><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="app-form-grid"><div><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div><div><label asp-for="Registration" class="form-label"></label><input asp-for="Registration" class="form-control" /><span asp-validation-for="Registration" class="text-danger"></span></div><div><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /><span asp-validation-for="Email" class="text-danger"></span></div><div><label asp-for="Phone" class="form-label"></label><input asp-for="Phone" class="form-control" /><span asp-validation-for="Phone" class="text-danger"></span></div><div><label asp-for="Password" class="form-label"></label><input asp-for="Password" class="form-control" type="password" /><span asp-validation-for="Password" class="text-danger"></span><div class="form-text">Preencha somente se quiser trocar a senha.</div></div><div><label asp-for="UserTypeId" class="form-label"></label><input asp-for="UserTypeId" class="form-control" /><span asp-validation-for="UserTypeId" class="text-danger"></span></div><div><label asp-for="Status" class="form-label"></label><input asp-for="Status" class="form-control" /><span asp-validation-for="Status" class="text-danger"></span></div><div><label asp-for="BeginTime" class="form-label"></label><input asp-for="BeginTime" class="form-control" type="datetime-local" /><span asp-validation-for="BeginTime" class="text-danger"></span></div><div><label asp-for="EndTime" class="form-label"></label><input asp-for="EndTime" class="form-control" type="datetime-local" /><span asp-validation-for="EndTime" class="text-danger"></span></div></div><div class="form-actions"><button type="submit" class="btn btn-warning">Salvar alterações</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div></form></section></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
