@model Integracao.ControlID.PoC.ViewModels.Users.UserDeleteViewModel
@{
    ViewData["Title"] = "Excluir usuário";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Excluir usuário",
        Description = "Revise o usuário selecionado antes de remover esse cadastro da base local da PoC.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para usuários", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card detail-card--danger app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div><div class="entity-overview__item"><span>Nome</span><strong>@Model.Name</strong></div><div class="entity-overview__item"><span>Matrícula</span><strong>@Model.Registration</strong></div></div><div class="app-note">A exclusão pode impactar cartões, QR Codes, biometria e demais vínculos operacionais do usuário.</div></section><section class="app-surface-card app-stack"><div class="alert alert-warning mb-0">Deseja realmente excluir o usuário <strong>@Model.Name</strong> (@Model.Registration)?</div><form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions">@Html.AntiForgeryToken()<button type="submit" class="btn btn-danger">Sim, excluir usuário</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></section></div>
