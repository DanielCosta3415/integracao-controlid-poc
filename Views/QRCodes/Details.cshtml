@model Integracao.ControlID.PoC.ViewModels.QRCodes.QRCodeViewModel
@{
    ViewData["Title"] = "Detalhes do QR Code";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Detalhes do QR Code",
        Description = "Consulte rapidamente os dados principais da credencial QR antes de editar ou remover esse registro.",
        BadgeText = "Consulta",
        BadgeTone = "neutral",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Editar QR Code", Href = Url.Action("Edit", new { id = Model.Id })!, ButtonClass = "btn btn-primary" }, new PageHeaderActionViewModel { Label = "Voltar para QR Codes", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />
    <section class="detail-card app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div><div class="entity-overview__item"><span>Usuário</span><strong>@Model.UserId</strong></div><div class="entity-overview__item"><span>Valor</span><strong>@Model.Value</strong></div></div></section>
    <section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Resumo do QR Code</strong><p>Visualização consolidada dos campos oficiais usados hoje pela PoC.</p></div></div><dl class="row"><dt class="col-sm-3">ID</dt><dd class="col-sm-9">@Model.Id</dd><dt class="col-sm-3">Usuário</dt><dd class="col-sm-9">@Model.UserId</dd><dt class="col-sm-3">Valor</dt><dd class="col-sm-9">@Model.Value</dd></dl></section>
</div>
