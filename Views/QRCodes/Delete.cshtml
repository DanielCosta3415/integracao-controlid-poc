@model Integracao.ControlID.PoC.ViewModels.QRCodes.QRCodeDeleteViewModel
@{
    ViewData["Title"] = "Excluir QR Code";
}

<div class="container mt-5">
    <div class="alert alert-warning">
        <h4>Confirmação</h4>
        <p>Deseja realmente excluir o QR Code <strong>@Model.Value</strong> do usuário <strong>@Model.UserId</strong>?</p>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger">Sim, excluir</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
        </form>
    </div>
</div>
