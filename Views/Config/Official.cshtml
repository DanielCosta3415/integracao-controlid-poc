@model Integracao.ControlID.PoC.ViewModels.Config.ConfigOfficialViewModel
@{
    ViewData["Title"] = "Configuração Oficial";
}

<div class="container mt-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1">Configuração Oficial JSON</h2>
            <p class="text-muted mb-0">Acessa diretamente os endpoints oficiais `get_configuration` e `set_configuration`.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar para Configurações</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Consultar Configuração</h5>
                    <p class="text-muted small">Informe o JSON de leitura exatamente como a API oficial espera.</p>
                    <form asp-action="GetOfficial" method="post" autocomplete="off">
                        <div class="mb-3">
                            <label asp-for="GetPayload" class="form-label"></label>
                            <textarea asp-for="GetPayload" class="form-control" rows="12"></textarea>
                            <span asp-validation-for="GetPayload" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary">Consultar</button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.GetResponseJson))
                    {
                        <div class="mt-4">
                            <h6>Resposta</h6>
                            <pre class="small mb-0">@Model.GetResponseJson</pre>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Alterar Configuração</h5>
                    <p class="text-muted small">Envie o JSON completo da alteração que será aplicada no equipamento.</p>
                    <form asp-action="SetOfficial" method="post" autocomplete="off">
                        <div class="mb-3">
                            <label asp-for="SetPayload" class="form-label"></label>
                            <textarea asp-for="SetPayload" class="form-control" rows="12"></textarea>
                            <span asp-validation-for="SetPayload" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-warning">Aplicar Alteração</button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.SetResponseJson))
                    {
                        <div class="mt-4">
                            <h6>Resposta</h6>
                            <pre class="small mb-0">@Model.SetResponseJson</pre>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
