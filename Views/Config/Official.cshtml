@model Integracao.ControlID.PoC.ViewModels.Config.ConfigOfficialViewModel
@{
    ViewData["Title"] = "Configuração oficial";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Infraestrutura",
        Title = "Configuração oficial JSON",
        Description = "Acesse diretamente os endpoints `get_configuration` e `set_configuration` com payloads JSON completos, sem sair do contexto visual da PoC.",
        BadgeText = "Explorador técnico",
        BadgeTone = "warning",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar para configurações", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <section class="app-grid-two app-grid-two--main">
        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Consultar configuração</strong>
                    <p>Informe o JSON de leitura exatamente como a API oficial espera.</p>
                </div>
            </div>

            <form asp-action="GetOfficial" method="post" autocomplete="off" class="form-section">
                <div>
                    <label asp-for="GetPayload" class="form-label"></label>
                    <textarea asp-for="GetPayload" class="form-control" rows="14"></textarea>
                    <span asp-validation-for="GetPayload" class="text-danger"></span>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Consultar</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.GetResponseJson))
            {
                <partial name="_RawResponsePanel" model='new RawResponsePanelViewModel { Title = "Resposta de leitura", Description = "JSON bruto retornado por `get_configuration`.", Content = Model.GetResponseJson, PanelId = "config-official-get", BadgeText = "get_configuration", BadgeTone = "neutral" }' />
            }
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Alterar configuração</strong>
                    <p>Envie o JSON completo da alteração que será aplicada no equipamento.</p>
                </div>
            </div>

            <form asp-action="SetOfficial" method="post" autocomplete="off" class="form-section">
                <div>
                    <label asp-for="SetPayload" class="form-label"></label>
                    <textarea asp-for="SetPayload" class="form-control" rows="14"></textarea>
                    <span asp-validation-for="SetPayload" class="text-danger"></span>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-warning">Aplicar alteração</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.SetResponseJson))
            {
                <partial name="_RawResponsePanel" model='new RawResponsePanelViewModel { Title = "Resposta de alteração", Description = "JSON bruto retornado por `set_configuration`.", Content = Model.SetResponseJson, PanelId = "config-official-set", BadgeText = "set_configuration", BadgeTone = "warning" }' />
            }
        </section>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
