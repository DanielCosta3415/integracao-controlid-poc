@model Integracao.ControlID.PoC.ViewModels.Config.ConfigDiagnosticsViewModel
@{
    ViewData["Title"] = "Diagnósticos";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Infraestrutura",
        Title = "Diagnósticos de rede",
        Description = "Execute testes oficiais de conexão TCP, ping e resolução DNS diretamente a partir do equipamento Control iD.",
        BadgeText = "Ferramenta técnica",
        BadgeTone = "info",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar para configurações", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <section class="app-grid-three">
        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Teste de conexão TCP</strong>
                    <p>Valide se o equipamento consegue abrir conexão até um host e porta específicos.</p>
                </div>
            </div>

            <form asp-action="ConnectionTest" method="post" autocomplete="off" class="form-section">
                <div>
                    <label asp-for="ConnectionHost" class="form-label"></label>
                    <input asp-for="ConnectionHost" class="form-control" />
                    <span asp-validation-for="ConnectionHost" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="ConnectionPort" class="form-label"></label>
                    <input asp-for="ConnectionPort" class="form-control" />
                    <span asp-validation-for="ConnectionPort" class="text-danger"></span>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Executar TCP</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ConnectionResultJson))
            {
                <partial name="_RawResponsePanel" model='new RawResponsePanelViewModel { Title = "Resposta TCP", Description = "JSON bruto do teste de conexão.", Content = Model.ConnectionResultJson, PanelId = "config-diagnostics-tcp", BadgeText = "TCP", BadgeTone = "neutral" }' />
            }
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Ping</strong>
                    <p>Execute um ping a partir do próprio equipamento Control iD.</p>
                </div>
            </div>

            <form asp-action="PingTest" method="post" autocomplete="off" class="form-section">
                <div>
                    <label asp-for="PingHost" class="form-label"></label>
                    <input asp-for="PingHost" class="form-control" />
                    <span asp-validation-for="PingHost" class="text-danger"></span>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Executar ping</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.PingResultJson))
            {
                <partial name="_RawResponsePanel" model='new RawResponsePanelViewModel { Title = "Resposta de ping", Description = "JSON bruto do ping oficial.", Content = Model.PingResultJson, PanelId = "config-diagnostics-ping", BadgeText = "Ping", BadgeTone = "neutral" }' />
            }
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>NSLookup</strong>
                    <p>Verifique a resolução DNS com a configuração atual do equipamento.</p>
                </div>
            </div>

            <form asp-action="NslookupTest" method="post" autocomplete="off" class="form-section">
                <div>
                    <label asp-for="NslookupHost" class="form-label"></label>
                    <input asp-for="NslookupHost" class="form-control" />
                    <span asp-validation-for="NslookupHost" class="text-danger"></span>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Executar NSLookup</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.NslookupResultJson))
            {
                <partial name="_RawResponsePanel" model='new RawResponsePanelViewModel { Title = "Resposta DNS", Description = "JSON bruto do teste NSLookup.", Content = Model.NslookupResultJson, PanelId = "config-diagnostics-nslookup", BadgeText = "NSLookup", BadgeTone = "neutral" }' />
            }
        </section>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
