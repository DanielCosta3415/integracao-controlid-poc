@model Integracao.ControlID.PoC.ViewModels.AccessRules.AccessRuleEditViewModel
@{
    ViewData["Title"] = "Nova regra de acesso";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Nova regra de acesso",
        Description = "Cadastre uma nova regra oficial definindo nome, tipo e prioridade com uma trilha de edição mais consistente com o restante da PoC.",
        BadgeText = "Criação",
        BadgeTone = "info",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar para regras", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <section class="detail-card app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>Nome</span><strong>@(string.IsNullOrWhiteSpace(Model.Name) ? "Não definido" : Model.Name)</strong></div>
            <div class="entity-overview__item"><span>Tipo</span><strong>@Model.Type</strong></div>
            <div class="entity-overview__item"><span>Prioridade</span><strong>@Model.Priority</strong></div>
        </div>
        <div class="app-note">Regras de acesso costumam ser sensíveis a ordem de prioridade. Ajuste o valor com cuidado antes de salvar a configuração no equipamento.</div>
    </section>

    <section class="app-surface-card app-stack">
        <div class="app-page-section__heading">
            <div>
                <strong>Parâmetros da regra</strong>
                <p>Preencha os campos oficiais confirmados para o objeto de regra de acesso.</p>
            </div>
        </div>

        <form asp-action="Create" method="post" autocomplete="off" class="form-section">
            <div class="app-form-grid">
                <div>
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Type" class="form-label"></label>
                    <input asp-for="Type" class="form-control" />
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Priority" class="form-label"></label>
                    <input asp-for="Priority" class="form-control" />
                    <span asp-validation-for="Priority" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Salvar regra</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
