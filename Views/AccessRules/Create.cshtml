@model Integracao.ControlID.PoC.ViewModels.AccessRules.AccessRuleEditViewModel
@{
    ViewData["Title"] = "Nova Regra de Acesso";
}

<div class="container mt-5">
    <h2>Nova Regra de Acesso</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post" autocomplete="off">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Type" class="form-label"></label>
                    <input asp-for="Type" class="form-control" />
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Priority" class="form-label"></label>
                    <input asp-for="Priority" class="form-control" />
                    <span asp-validation-for="Priority" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success">Salvar</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
