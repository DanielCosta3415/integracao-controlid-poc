@model Integracao.ControlID.PoC.ViewModels.AccessRules.AccessRuleListViewModel
@{
    ViewData["Title"] = "Regras de acesso";
    ViewData["Subtitle"] = "Policies e time zones aplicados aos usuários e grupos vinculados ao equipamento.";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas e credenciais",
        Title = "Regras de acesso",
        Description = "Centralize as políticas de autorização, acompanhe prioridade e entre rápido nos fluxos de manutenção.",
        BadgeText = $"{(Model.AccessRules?.Count() ?? 0)} regras",
        BadgeTone = "neutral",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Nova regra", Href = Url.Action("Create")!, ButtonClass = "btn btn-primary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <section class="app-surface-card app-page-section">
        <div class="app-page-section__heading">
            <div>
                <strong>Políticas disponíveis</strong>
                <p>As regras oficiais abaixo ajudam a compor os cenários de acesso por tipo, prioridade e vínculo com usuários ou grupos.</p>
            </div>
            <span class="app-chip app-chip--neutral">CRUD oficial</span>
        </div>

        <table class="table table-borderless table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>Prioridade</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.AccessRules != null && Model.AccessRules.Any())
                {
                    foreach (var rule in Model.AccessRules)
                    {
                        <tr>
                            <td>@rule.Id</td>
                            <td>
                                <div class="app-table-cell-stack">
                                    <strong>@rule.Name</strong>
                                    <small>Regra oficial cadastrada no equipamento</small>
                                </div>
                            </td>
                            <td><span class="app-chip app-chip--neutral">@rule.Type</span></td>
                            <td>@rule.Priority</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@rule.Id" class="btn btn-sm btn-info">Detalhes</a>
                                <a asp-action="Edit" asp-route-id="@rule.Id" class="btn btn-sm btn-primary">Editar</a>
                                <a asp-action="Delete" asp-route-id="@rule.Id" class="btn btn-sm btn-danger" data-confirm="Deseja excluir esta regra?">Excluir</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">
                            <div class="app-empty app-empty--center">Nenhuma regra de acesso encontrada.</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</div>
