@model Integracao.ControlID.PoC.ViewModels.AccessRules.AccessRuleViewModel
@{
    ViewData["Title"] = "Detalhes da regra de acesso";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Detalhes da regra de acesso",
        Description = "Veja os parâmetros essenciais da regra antes de editar, reordenar prioridades ou excluir o registro.",
        BadgeText = "Detalhe",
        BadgeTone = "neutral",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Editar", Href = Url.Action("Edit", new { id = Model.Id })!, ButtonClass = "btn btn-primary" },
            new PageHeaderActionViewModel { Label = "Voltar para regras", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <section class="detail-card app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div>
            <div class="entity-overview__item"><span>Nome</span><strong>@Model.Name</strong></div>
            <div class="entity-overview__item"><span>Tipo</span><strong>@Model.Type</strong></div>
            <div class="entity-overview__item"><span>Prioridade</span><strong>@Model.Priority</strong></div>
        </div>
    </section>

    <section class="app-surface-card app-stack">
        <div class="app-page-section__heading">
            <div>
                <strong>Dados oficiais</strong>
                <p>Resumo detalhado dos campos carregados para esta regra de acesso.</p>
            </div>
        </div>

        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>
            <dt class="col-sm-3">Nome</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">Tipo</dt>
            <dd class="col-sm-9">@Model.Type</dd>
            <dt class="col-sm-3">Prioridade</dt>
            <dd class="col-sm-9">@Model.Priority</dd>
        </dl>
    </section>
</div>
