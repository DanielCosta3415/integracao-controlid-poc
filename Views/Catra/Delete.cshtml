@model Integracao.ControlID.PoC.ViewModels.Catra.CatraEventViewModel
@{
    ViewData["Title"] = "Excluir evento de catraca";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Excluir evento de catraca",
        Description = "Revise o evento selecionado antes de removê-lo da base local usada na PoC.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para catraca", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card detail-card--danger app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div><div class="entity-overview__item"><span>Usuário</span><strong>@Model.UserId</strong></div><div class="entity-overview__item"><span>Dispositivo</span><strong>@Model.DeviceId</strong></div></div><div class="app-note">A exclusão remove o histórico local desse evento de catraca e pode afetar análise de auditoria ou diagnóstico.</div></section><section class="app-surface-card app-stack"><div class="alert alert-warning mb-0">Deseja realmente excluir o evento de catraca de ID <strong>@Model.Id</strong>?</div><form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions"><button type="submit" class="btn btn-danger">Sim, excluir evento</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></section></div>

