@model Integracao.ControlID.PoC.ViewModels.Errors.ErrorViewModel
@{
    ViewData["Title"] = "Detalhes do erro";
    ViewData["Subtitle"] = "Inspeção técnica do incidente persistido pela aplicação.";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Eventos, logs e push",
        Title = "Detalhes do erro",
        Description = "Revise a rota afetada, o usuário e o request id sem expor stack traces completos na interface.",
        BadgeText = $"Status {Model.StatusCode}",
        BadgeTone = "warning",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar aos erros", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
    var stackPanel = new RawResponsePanelViewModel
    {
        PanelId = "error-stack-trace",
        Title = "Detalhes técnicos protegidos",
        Description = "Para hardening da PoC, stack trace e exceções internas completas permanecem disponíveis apenas nos logs do servidor.",
        Content = "Consulte o request id e os logs do servidor para investigar este incidente em profundidade.",
        BadgeText = string.IsNullOrWhiteSpace(Model.RequestId) ? "Sem request id" : $"Request {Model.RequestId}",
        BadgeTone = "warning"
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <section class="app-surface-card app-detail-shell">
        <dl class="app-detail-list">
            <div class="app-detail-list__row"><dt>Mensagem</dt><dd>@Model.Message</dd></div>
            <div class="app-detail-list__row"><dt>Path</dt><dd>@Model.Path</dd></div>
            <div class="app-detail-list__row"><dt>Status code</dt><dd><span class="app-chip app-chip--warning">@Model.StatusCode</span></dd></div>
            <div class="app-detail-list__row"><dt>Usuário</dt><dd>@(string.IsNullOrWhiteSpace(Model.User) ? "-" : Model.User)</dd></div>
            <div class="app-detail-list__row"><dt>Data e hora</dt><dd>@(Model.OccurredAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd></div>
            <div class="app-detail-list__row"><dt>Request ID</dt><dd>@(string.IsNullOrWhiteSpace(Model.RequestId) ? "-" : Model.RequestId)</dd></div>
            <div class="app-detail-list__row"><dt>Inner exception</dt><dd>Disponível apenas nos logs do servidor.</dd></div>
            <div class="app-detail-list__row"><dt>Dados adicionais</dt><dd>@(string.IsNullOrWhiteSpace(Model.AdditionalData) ? "-" : Model.AdditionalData)</dd></div>
        </dl>
    </section>

    <partial name="_RawResponsePanel" model="stackPanel" />
</div>
