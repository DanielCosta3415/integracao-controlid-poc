@model Integracao.ControlID.PoC.ViewModels.Monitor.MonitorPushListViewModel
@{
    ViewData["Title"] = "Eventos push";
    ViewData["Subtitle"] = "Fila histórica dos eventos push recebidos pela trilha legada de monitoramento.";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Eventos, logs e push",
        Title = "Eventos push",
        Description = "Inspecione os eventos recebidos, o tipo de comando associado e o payload resumido antes de abrir o detalhe técnico.",
        BadgeText = $"{(Model.Events?.Count() ?? 0)} eventos",
        BadgeTone = "info"
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <section class="app-surface-card app-page-section">
        <div class="app-page-section__heading">
            <div>
                <strong>Monitor de eventos push</strong>
                <p>Esta visão resume a trilha legada para apoio de diagnóstico e conferência de payloads.</p>
            </div>
        </div>

        <table class="table table-borderless table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Quando</th>
                    <th>Comando</th>
                    <th>Status</th>
                    <th>Dispositivo</th>
                    <th>Usuário</th>
                    <th>Payload</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Events != null && Model.Events.Any())
                {
                    foreach (var evt in Model.Events)
                    {
                        <tr>
                            <td>@evt.EventId</td>
                            <td>@evt.ReceivedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="app-chip app-chip--neutral">@evt.CommandType</span></td>
                            <td><span class="app-chip app-chip--info">@evt.Status</span></td>
                            <td>@evt.DeviceId</td>
                            <td>@evt.UserId</td>
                            <td>
                                <div class="app-table-cell-stack">
                                    <strong>@(string.IsNullOrWhiteSpace(evt.Payload) ? "Sem payload" : (evt.Payload.Length > 48 ? evt.Payload.Substring(0, 48) + "..." : evt.Payload))</strong>
                                    <small>Resposta original disponível no detalhe</small>
                                </div>
                            </td>
                            <td>
                                <a asp-action="PushDetails" asp-route-id="@evt.EventId" class="btn btn-sm btn-info">Detalhes</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="app-empty app-empty--center">Nenhum evento push recebido.</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</div>
