@model Integracao.ControlID.PoC.ViewModels.AdvancedOfficial.FacialEnrollViewModel
@{
    ViewData["Title"] = "Cadastro Facial Avançado";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1">Cadastro Facial Avançado</h2>
            <p class="text-muted mb-0">Fluxos dedicados para `user_get_image_list`, `user_set_image_list` e `user_test_image`.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">@Model.ResultMessage</div>
    }

    <div class="row g-4">
        <div class="col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5>Consultar Fotos por Usuário</h5>
                    <form asp-action="GetImageList" method="post" autocomplete="off">
                        <div class="mb-3">
                            <label asp-for="UserIdsCsv" class="form-label"></label>
                            <input asp-for="UserIdsCsv" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-primary">Consultar</button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.GetListResponseJson))
                    {
                        <hr />
                        <pre class="small mb-0">@Model.GetListResponseJson</pre>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5>Testar Foto Facial</h5>
                    <form asp-action="TestImage" method="post" enctype="multipart/form-data" autocomplete="off">
                        <div class="mb-3">
                            <label asp-for="TestFile" class="form-label"></label>
                            <input asp-for="TestFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                        </div>
                        <button type="submit" class="btn btn-outline-primary">Testar</button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.TestResponseJson))
                    {
                        <hr />
                        <pre class="small mb-0">@Model.TestResponseJson</pre>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>Cadastro em Lote</h5>
                    <p class="text-muted small">Informe a mesma quantidade de IDs e arquivos, na mesma ordem.</p>
                    <form asp-action="SetImageList" method="post" enctype="multipart/form-data" autocomplete="off">
                        <div class="row g-3">
                            <div class="col-lg-8">
                                <label asp-for="UserIdsCsv" class="form-label"></label>
                                <input asp-for="UserIdsCsv" class="form-control" />
                            </div>
                            <div class="col-lg-4 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input asp-for="MatchDuplicates" class="form-check-input" />
                                    <label asp-for="MatchDuplicates" class="form-check-label"></label>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3">
                            <label asp-for="BatchFiles" class="form-label"></label>
                            <input asp-for="BatchFiles" class="form-control" type="file" multiple accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn btn-success">Cadastrar Lote</button>
                        </div>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.SetListResponseJson))
                    {
                        <hr />
                        <pre class="small mb-0">@Model.SetListResponseJson</pre>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
