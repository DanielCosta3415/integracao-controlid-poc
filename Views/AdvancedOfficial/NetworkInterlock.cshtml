@model Integracao.ControlID.PoC.ViewModels.AdvancedOfficial.NetworkInterlockViewModel
@{
    ViewData["Title"] = "Intertravamento em Rede";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1">Intertravamento em Rede</h2>
            <p class="text-muted mb-0">Fluxo dedicado para `set_network_interlock.fcgi`.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">@Model.ResultMessage</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="NetworkInterlock" method="post">
                <div class="form-check mb-3">
                    <input asp-for="InterlockEnabled" class="form-check-input" />
                    <label asp-for="InterlockEnabled" class="form-check-label"></label>
                </div>
                <div class="form-check mb-3">
                    <input asp-for="ApiBypassEnabled" class="form-check-input" />
                    <label asp-for="ApiBypassEnabled" class="form-check-label"></label>
                </div>
                <div class="form-check mb-3">
                    <input asp-for="RexBypassEnabled" class="form-check-input" />
                    <label asp-for="RexBypassEnabled" class="form-check-label"></label>
                </div>
                <button type="submit" class="btn btn-primary">Aplicar</button>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ResponseJson))
            {
                <hr />
                <h5>Resposta Oficial</h5>
                <pre class="small mb-0">@Model.ResponseJson</pre>
            }
        </div>
    </div>
</div>
