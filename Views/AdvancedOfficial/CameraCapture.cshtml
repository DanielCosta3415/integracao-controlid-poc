@model Integracao.ControlID.PoC.ViewModels.AdvancedOfficial.CameraCaptureViewModel
@{
    ViewData["Title"] = "Captura da câmera";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "API",
        Title = "Captura da câmera",
        Description = "Fluxo dedicado para `save_screenshot.fcgi`, com visualização imediata da imagem capturada e do retorno técnico oficial.",
        BadgeText = "Recurso avançado",
        BadgeTone = "info",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
    var responsePanel = string.IsNullOrWhiteSpace(Model.ResponseJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Detalhes técnicos",
            Description = "JSON bruto retornado pelo endpoint `save_screenshot.fcgi`.",
            Content = Model.ResponseJson,
            PanelId = "advanced-camera-capture-response",
            BadgeText = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "Retorno técnico" : Model.ResultStatusType,
            BadgeTone = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "neutral" : Model.ResultStatusType,
            StartExpanded = true
        };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">@Model.ResultMessage</div>
    }

    <section class="app-grid-two app-grid-two--main">
        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Parâmetros da captura</strong>
                    <p>Defina o tipo de frame e a câmera de origem antes de solicitar o screenshot ao equipamento.</p>
                </div>
            </div>

            <form asp-action="CameraCapture" method="post" autocomplete="off" class="form-section">
                <div class="app-form-grid">
                    <div>
                        <label asp-for="FrameType" class="form-label"></label>
                        <input asp-for="FrameType" class="form-control" />
                    </div>
                    <div>
                        <label asp-for="Camera" class="form-label"></label>
                        <select asp-for="Camera" class="form-select">
                            <option value="rgb">rgb</option>
                            <option value="ir">ir</option>
                        </select>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Capturar imagem</button>
                </div>
            </form>
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Prévia operacional</strong>
                    <p>A imagem capturada aparece abaixo assim que a chamada retorna com sucesso.</p>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Base64Image))
            {
                <img src="data:@Model.ImageContentType;base64,@Model.Base64Image"
                     alt="Captura"
                     class="img-fluid rounded border"
                     decoding="async" />
            }
            else
            {
                <div class="app-empty">Nenhuma captura disponível ainda. Execute a ação para visualizar a imagem aqui.</div>
            }
        </section>
    </section>

    @if (responsePanel != null)
    {
        <partial name="_RawResponsePanel" model="responsePanel" />
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
