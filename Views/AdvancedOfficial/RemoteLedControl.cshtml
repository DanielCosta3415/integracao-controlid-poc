@model Integracao.ControlID.PoC.ViewModels.AdvancedOfficial.RemoteLedControlViewModel
@{
    ViewData["Title"] = "LED Remoto";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1">LED Remoto</h2>
            <p class="text-muted mb-0">Fluxo dedicado para `remote_led_control.fcgi`.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">@Model.ResultMessage</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="RemoteLedControl" method="post">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Color" class="form-label"></label>
                        <input asp-for="Color" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Event" class="form-label"></label>
                        <input asp-for="Event" class="form-control" type="number" min="0" max="4" />
                    </div>
                </div>
                <div class="mt-3 small text-muted">
                    Eventos: 0 autorizado, 1 negado, 2 idle, 3 desligar, 4 mudar cor idle.
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Enviar Comando</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ResponseJson))
            {
                <hr />
                <h5>Resposta Oficial</h5>
                <pre class="small mb-0">@Model.ResponseJson</pre>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
