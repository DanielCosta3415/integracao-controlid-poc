@model Integracao.ControlID.PoC.ViewModels.AdvancedOfficial.RemoteLedControlViewModel
@{
    ViewData["Title"] = "LED remoto";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "API",
        Title = "LED remoto",
        Description = "Fluxo dedicado para `remote_led_control.fcgi`, com contexto visual melhor para cor, evento e retorno técnico.",
        BadgeText = "Recurso avançado",
        BadgeTone = "info",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
    var responsePanel = string.IsNullOrWhiteSpace(Model.ResponseJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Resposta oficial",
            Description = "JSON bruto retornado pelo endpoint `remote_led_control.fcgi`.",
            Content = Model.ResponseJson,
            PanelId = "advanced-remote-led-response",
            BadgeText = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "Retorno técnico" : Model.ResultStatusType,
            BadgeTone = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "neutral" : Model.ResultStatusType,
            StartExpanded = true
        };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">@Model.ResultMessage</div>
    }

    <section class="detail-card app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>Cor</span><strong>@(string.IsNullOrWhiteSpace(Model.Color) ? "Não definida" : Model.Color)</strong></div>
            <div class="entity-overview__item"><span>Evento</span><strong>@Model.Event</strong></div>
        </div>
        <div class="app-note">Eventos suportados: 0 autorizado, 1 negado, 2 idle, 3 desligar, 4 alterar cor idle.</div>
    </section>

    <section class="app-grid-two app-grid-two--main">
        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Enviar comando ao LED</strong>
                    <p>Defina a cor desejada e o evento a ser associado ao indicador visual remoto do equipamento.</p>
                </div>
            </div>

            <form asp-action="RemoteLedControl" method="post" class="form-section">
                <div class="app-form-grid">
                    <div>
                        <label asp-for="Color" class="form-label"></label>
                        <input asp-for="Color" class="form-control" placeholder="green, red, blue..." />
                    </div>
                    <div>
                        <label asp-for="Event" class="form-label"></label>
                        <input asp-for="Event" class="form-control" type="number" min="0" max="4" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Enviar comando</button>
                </div>
            </form>
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Orientação de uso</strong>
                    <p>Esse fluxo é útil para demonstrações, troubleshooting visual e adequação de feedback luminoso em cenários específicos.</p>
                </div>
            </div>

            <div class="app-note">Prefira cores previamente homologadas pelo equipamento e mantenha a documentação operacional alinhada com o significado de cada evento visual.</div>
        </section>
    </section>

    @if (responsePanel != null)
    {
        <partial name="_RawResponsePanel" model="responsePanel" />
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
