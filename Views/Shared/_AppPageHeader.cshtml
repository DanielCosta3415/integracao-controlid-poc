@model Integracao.ControlID.PoC.ViewModels.Shared.AppPageHeaderViewModel
@{
    var eyebrow = SecurityTextHelper.NormalizeForDisplay(Model.Eyebrow, string.Empty);
    var title = SecurityTextHelper.NormalizeForDisplay(Model.Title, "Painel");
    var description = SecurityTextHelper.NormalizeForDisplay(Model.Description, string.Empty);
    var badgeText = SecurityTextHelper.NormalizeForDisplay(Model.BadgeText, string.Empty);
}

<div class="app-page-header">
    <div class="app-page-header__content">
        @if (!string.IsNullOrWhiteSpace(eyebrow))
        {
            <div class="app-page-header__eyebrow">@eyebrow</div>
        }
        <div class="app-page-header__main">
            <div>
                <h1 class="app-page-header__title">@title</h1>
                @if (!string.IsNullOrWhiteSpace(description))
                {
                    <p class="app-page-header__description">@description</p>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(badgeText))
            {
                <span class="app-chip app-chip--@Model.BadgeTone">@badgeText</span>
            }
        </div>
    </div>

    @if (Model.Actions.Any())
    {
        <div class="app-page-header__actions">
            @foreach (var action in Model.Actions)
            {
                var label = SecurityTextHelper.NormalizeForDisplay(action.Label, "Abrir ação");
                var ariaLabel = SecurityTextHelper.NormalizeForDisplay(action.AriaLabel, $"{label} na página {title}");
                if (action.NewTab)
                {
                    <a href="@action.Href"
                       class="@action.ButtonClass"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="@ariaLabel">
                        @label
                    </a>
                }
                else
                {
                    <a href="@action.Href" class="@action.ButtonClass" aria-label="@ariaLabel">@label</a>
                }
            }
        </div>
    }
</div>
