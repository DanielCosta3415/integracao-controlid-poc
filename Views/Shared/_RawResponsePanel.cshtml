@model Integracao.ControlID.PoC.ViewModels.Shared.RawResponsePanelViewModel
@{
    var panelId = string.IsNullOrWhiteSpace(Model.PanelId) ? $"raw-panel-{Guid.NewGuid():N}" : Model.PanelId;
    var summaryId = $"{panelId}-summary";
    var title = SecurityTextHelper.NormalizeForDisplay(Model.Title, "Resposta técnica");
    var description = SecurityTextHelper.NormalizeForDisplay(Model.Description, string.Empty);
    var badgeText = SecurityTextHelper.NormalizeForDisplay(Model.BadgeText, string.Empty);
}

<details class="raw-panel" @(Model.StartExpanded ? "open" : null)>
    <summary class="raw-panel__summary"
             id="@summaryId"
             aria-label="Alternar painel de resposta bruta"
             aria-controls="@panelId">
        <div class="raw-panel__summary-copy">
            <strong>@title</strong>
            @if (!string.IsNullOrWhiteSpace(description))
            {
                <span>@description</span>
            }
        </div>
        <div class="raw-panel__summary-actions">
            @if (!string.IsNullOrWhiteSpace(badgeText))
            {
                <span class="app-chip app-chip--@Model.BadgeTone">@badgeText</span>
            }
            <button type="button"
                    class="btn btn-quiet btn-sm"
                    data-copy-target="@panelId"
                    aria-label="Copiar o conteúdo bruto exibido neste painel">
                Copiar
            </button>
        </div>
    </summary>
    <pre id="@panelId" class="app-code-panel" tabindex="0" aria-labelledby="@summaryId">@Model.Content</pre>
</details>
