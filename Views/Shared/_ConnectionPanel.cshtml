@using Integracao.ControlID.PoC.Helpers
@model ConnectionPanelViewModel

@{
    var baseAddress = SecurityTextHelper.NormalizeForDisplay(Model.BaseAddress, "Base não informada");
    var deviceName = SecurityTextHelper.NormalizeForDisplay(Model.DeviceName, "n/d");
}

<section class="connection-rail" id="connectionPanel" aria-label="Contexto de conexão do equipamento" aria-describedby="connectionPanelHelp connectionPanelState">
    <div class="connection-rail__status">
        <div class="connection-rail__status-top">
            <span class="app-chip @(Model.IsDeviceConnected ? "app-chip--success" : "app-chip--warning")">
                @(Model.IsDeviceConnected ? "Equipamento em contexto" : "Conexão pendente")
            </span>
            <strong>Equipamento de trabalho</strong>
        </div>
        <small id="connectionPanelHelp">Informe protocolo, IP ou domínio e porta para testar a comunicação ou trocar o equipamento ativo da PoC.</small>

        @if (Model.IsDeviceConnected)
        {
            <div class="connection-rail__summary" id="connectionPanelState" role="status" aria-live="polite">
                <div class="connection-pill connection-pill--wide">
                    <span>Base ativa</span>
                    <strong>@baseAddress</strong>
                </div>
                <div class="connection-pill">
                    <span>Equipamento</span>
                    <strong>@deviceName</strong>
                </div>
                <div class="connection-pill">
                    <span>Sessão</span>
                    <strong>@(Model.IsSessionActive ? "Ativa" : "Inativa")</strong>
                </div>
            </div>
        }
        else
        {
            <div class="connection-rail__summary" id="connectionPanelState" role="status" aria-live="polite">
                <div class="connection-pill connection-pill--wide">
                    <span>Contexto atual</span>
                    <strong>Nenhum equipamento conectado.</strong>
                </div>
            </div>
        }
    </div>

    <form asp-controller="Home" asp-action="ConnectToDevice" method="post" class="connection-rail__form" autocomplete="off" aria-label="Formulário de conexão com equipamento">
        <input asp-for="ReturnUrl" type="hidden" />

        <div class="connection-rail__field connection-rail__field--scheme">
            <label asp-for="Scheme" class="form-label">Protocolo</label>
            <select asp-for="Scheme" class="form-select" aria-describedby="connectionPanelHelp connectionPanelState">
                <option value="http">http</option>
                <option value="https">https</option>
            </select>
        </div>

        <div class="connection-rail__field connection-rail__field--host">
            <label asp-for="Host" class="form-label">IP ou domínio</label>
            <input asp-for="Host"
                   class="form-control"
                   placeholder="192.168.0.10, controlid.local ou URL completa"
                   aria-describedby="connectionPanelHelp connectionPanelState" />
        </div>

        <div class="connection-rail__field connection-rail__field--port">
            <label asp-for="Port" class="form-label">Porta</label>
            <input asp-for="Port"
                   class="form-control"
                   inputmode="numeric"
                   placeholder="80 / 443 / personalizada"
                   aria-describedby="connectionPanelHelp connectionPanelState" />
        </div>

        <div class="connection-rail__actions">
            <button type="submit" class="btn btn-primary" aria-label="Conectar equipamento usando protocolo, host e porta informados">Conectar</button>
            <button type="submit"
                    class="btn btn-outline-secondary"
                    formaction="@Url.Action("TestDeviceConnectivity", "Home")"
                    aria-label="Testar comunicação com o equipamento usando protocolo, host e porta informados">
                Testar
            </button>
            <a class="btn btn-quiet" href="@Url.Action("Status", "Session")" aria-label="Abrir o status da sessão atual">Sessão</a>
        </div>
    </form>
</section>
