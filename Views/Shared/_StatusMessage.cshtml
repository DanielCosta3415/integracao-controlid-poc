@model string

@{
    var message = SecurityTextHelper.NormalizeForDisplay(Model, string.Empty);
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info alert-dismissible fade show" role="status" aria-live="assertive" aria-atomic="true">
        @message
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar alerta"></button>
    </div>
}
