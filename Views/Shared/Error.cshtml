@model Integracao.ControlID.PoC.ViewModels.Errors.ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<div class="container mt-5">
    <h2 class="text-danger">Ocorreu um erro</h2>
    <div class="alert alert-danger">
        <p><strong>@Model.Message</strong></p>
        <p class="mb-0">Os detalhes técnicos completos foram preservados apenas nos logs do servidor para evitar exposição de informações sensíveis.</p>
        @if (!string.IsNullOrEmpty(Model.RequestId))
        {
            <p class="mt-3"><small>ID da Requisição: <code>@Model.RequestId</code></small></p>
        }
    </div>
    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Voltar para a página inicial</a>
</div>
