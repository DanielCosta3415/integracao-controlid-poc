@model PageShellContextViewModel
@inject Integracao.ControlID.PoC.Services.Navigation.NavigationCatalogService NavigationCatalog
@{
    var domains = NavigationCatalog.GetDomains();
    var activeDomainId = Model.CurrentDomain?.Id ?? string.Empty;
    var activeModuleKey = Model.CurrentModule?.Key ?? string.Empty;
}

<nav class="app-nav" aria-label="Módulos da aplicação">
    <a class="app-nav-home @(string.IsNullOrWhiteSpace(activeDomainId) && string.IsNullOrWhiteSpace(activeModuleKey) ? "is-active" : null)"
       href="@Url.Action("Index", "Home")">
        Painel
    </a>

    @foreach (var domain in domains)
    {
        var isActiveDomain = string.Equals(activeDomainId, domain.Id, StringComparison.OrdinalIgnoreCase);
        var primaryModules = domain.Modules
            .Where(module => module.Visibility == "primary")
            .OrderBy(module => module.Priority)
            .ToList();
        var secondaryCount = domain.Modules.Count - primaryModules.Count;
        var detailsClass = $"app-nav-domain{(isActiveDomain ? " is-current-domain" : string.Empty)}";

        <details class="@detailsClass" data-topnav-menu>
            <summary class="app-nav-domain__summary">
                <span class="app-nav-domain__summary-copy">
                    <strong>@domain.ShortTitle</strong>
                    <small>@primaryModules.Count módulos principais</small>
                </span>
                <span class="app-nav-domain__summary-icon" aria-hidden="true">@domain.Icon</span>
            </summary>

            <div class="app-nav-domain__panel">
                <div class="app-nav-domain__panel-head">
                    <div class="app-stack-sm">
                        <span class="app-chip app-chip--@domain.AccentTone">@domain.Title</span>
                        <strong>@domain.Description</strong>
                        <p>@domain.Summary</p>
                    </div>
                    <div class="quick-links">
                        <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Domain", "Workspace", new { id = domain.Id })">Abrir domínio</a>
                    </div>
                </div>

                <div class="app-nav-domain__grid">
                    @foreach (var item in primaryModules)
                    {
                        var isActive = string.Equals(activeModuleKey, item.Key, StringComparison.OrdinalIgnoreCase)
                            || string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), item.Controller, StringComparison.OrdinalIgnoreCase)
                               && string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), item.Action, StringComparison.OrdinalIgnoreCase);
                        var href = Url.Action(item.Action, item.Controller) ?? "#";

                        <article class="app-nav-module @(isActive ? "is-active" : null)">
                            <a class="app-nav-module__link"
                               href="@href"
                               data-module-link
                               data-module-key="@item.Key"
                               data-module-group="@domain.Title"
                               data-module-label="@item.Label"
                               data-module-tags="@item.Tags"
                               data-module-short="@item.ShortLabel">
                                <span class="app-nav-module__icon">@item.ShortLabel</span>
                                <span class="app-nav-module__copy">
                                    <strong>@item.Label</strong>
                                    <small>@item.Description</small>
                                </span>
                            </a>
                            <button type="button"
                                    class="app-nav-module__favorite"
                                    data-favorite-toggle
                                    data-module-key="@item.Key"
                                    data-module-label="@item.Label"
                                    aria-label="Fixar @item.Label nos favoritos"
                                    title="Fixar nos favoritos">
                                ☆
                            </button>
                        </article>
                    }
                </div>

                @if (secondaryCount > 0)
                {
                    <div class="app-nav-domain__footer">
                        <span class="app-chip app-chip--neutral">+@secondaryCount telas especializadas</span>
                        <a class="btn btn-quiet btn-sm" href="@Url.Action("Domain", "Workspace", new { id = domain.Id })">Ver tudo neste domínio</a>
                    </div>
                }
            </div>
        </details>
    }
</nav>
