@model Integracao.ControlID.PoC.ViewModels.Devices.DeviceEditViewModel
@{
    ViewData["Title"] = "Editar Dispositivo";
}

<div class="container mt-5">
    <h2>Editar Dispositivo</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post" autocomplete="off">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Ip" class="form-label"></label>
                    <input asp-for="Ip" class="form-control" />
                    <span asp-validation-for="Ip" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SerialNumber" class="form-label"></label>
                    <input asp-for="SerialNumber" class="form-control" />
                    <span asp-validation-for="SerialNumber" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Firmware" class="form-label"></label>
                    <input asp-for="Firmware" class="form-control" />
                    <span asp-validation-for="Firmware" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <input asp-for="Status" class="form-control" />
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
