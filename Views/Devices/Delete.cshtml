@model Integracao.ControlID.PoC.ViewModels.Devices.DeviceDeleteViewModel
@{
    ViewData["Title"] = "Excluir dispositivo";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Infraestrutura",
        Title = "Excluir dispositivo",
        Description = "Revise o dispositivo selecionado antes de removê-lo da base local usada pela PoC.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para dispositivos", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card detail-card--danger app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div><div class="entity-overview__item"><span>Nome</span><strong>@Model.Name</strong></div></div><div class="app-note">A exclusão remove o dispositivo da base gerenciada pela PoC e pode invalidar atalhos ou sessões associados.</div></section><section class="app-surface-card app-stack"><div class="alert alert-warning mb-0">Deseja realmente excluir o dispositivo <strong>@Model.Name</strong>?</div><form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions"><button type="submit" class="btn btn-danger">Sim, excluir dispositivo</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></section></div>
