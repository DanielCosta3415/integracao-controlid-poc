@model Integracao.ControlID.PoC.ViewModels.AccessLogs.AccessLogDeleteViewModel
@{
    ViewData["Title"] = "Excluir log de acesso";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Observabilidade",
        Title = "Excluir log de acesso",
        Description = "Revise o registro selecionado antes de remover esse log de acesso da base local da PoC.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para logs de acesso", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card detail-card--danger app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div><div class="entity-overview__item"><span>Info</span><strong>@Model.Info</strong></div></div></section><section class="app-surface-card app-stack"><div class="alert alert-warning mb-0">Deseja realmente excluir o log de acesso com info <strong>@Model.Info</strong>?</div><form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="form-actions"><button type="submit" class="btn btn-danger">Sim, excluir log</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></section></div>
