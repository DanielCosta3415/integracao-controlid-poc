@model Integracao.ControlID.PoC.ViewModels.AccessLogs.AccessLogDeleteViewModel
@{
    ViewData["Title"] = "Excluir Log de Acesso";
}

<div class="container mt-5">
    <div class="alert alert-warning">
        <h4>Confirmação</h4>
        <p>Deseja realmente excluir o log de acesso com info <strong>@Model.Info</strong>?</p>
        <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger">Sim, excluir</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
        </form>
    </div>
</div>