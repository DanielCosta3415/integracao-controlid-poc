@model Integracao.ControlID.PoC.ViewModels.Media.PhotoDeleteViewModel
@{
    ViewData["Title"] = "Excluir foto";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Excluir foto do usuário",
        Description = "Revise a imagem selecionada antes de remover a foto facial vinculada ao usuário.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para fotos", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card detail-card--danger app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>Usuário</span><strong>@Model.UserId</strong></div><div class="entity-overview__item"><span>Arquivo</span><strong>@Model.FileName</strong></div></div><div class="app-note">A exclusão remove a foto facial persistida e pode impactar reconhecimento, identificação ou conferência visual do usuário.</div></section><section class="app-surface-card app-stack"><div class="alert alert-warning mb-0">Deseja realmente excluir a foto <strong>@Model.FileName</strong> do usuário <strong>@Model.UserId</strong>?</div><form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions">@Html.AntiForgeryToken()<button type="submit" class="btn btn-danger">Sim, excluir foto</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></section></div>
