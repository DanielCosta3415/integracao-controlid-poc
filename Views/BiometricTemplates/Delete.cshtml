@model Integracao.ControlID.PoC.ViewModels.BiometricTemplates.BiometricTemplateDeleteViewModel
@{
    ViewData["Title"] = "Excluir template biométrico";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Excluir template biométrico",
        Description = "Revise o template selecionado antes de confirmar a remoção do cadastro biométrico do usuário.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para templates", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />
    <section class="detail-card detail-card--danger app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div>
            <div class="entity-overview__item"><span>Usuário</span><strong>@Model.UserId</strong></div>
        </div>
        <div class="app-note">A exclusão remove o template biométrico persistido localmente e pode impactar validações faciais ou digitais associadas.</div>
    </section>
    <section class="app-surface-card app-stack">
        <div class="alert alert-warning mb-0">Deseja realmente excluir o template biométrico do usuário <strong>@Model.UserId</strong>?</div>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Sim, excluir template</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </section>
</div>
