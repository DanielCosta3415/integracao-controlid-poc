@model Integracao.ControlID.PoC.ViewModels.BiometricTemplates.BiometricTemplateEditViewModel
@{
    ViewData["Title"] = "Novo Template Biométrico";
}

<div class="container mt-5">
    <h2>Novo Template Biométrico</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post" autocomplete="off">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="UserId" class="form-label"></label>
                    <input asp-for="UserId" class="form-control" />
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Template" class="form-label"></label>
                    <textarea asp-for="Template" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Template" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Type" class="form-label"></label>
                    <input asp-for="Type" class="form-control" />
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="FingerPosition" class="form-label"></label>
                    <input asp-for="FingerPosition" class="form-control" />
                    <span asp-validation-for="FingerPosition" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="FingerType" class="form-label"></label>
                    <input asp-for="FingerType" class="form-control" />
                    <span asp-validation-for="FingerType" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="BeginTime" class="form-label"></label>
                    <input asp-for="BeginTime" class="form-control" type="datetime-local" />
                    <span asp-validation-for="BeginTime" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EndTime" class="form-label"></label>
                    <input asp-for="EndTime" class="form-control" type="datetime-local" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success">Salvar</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
