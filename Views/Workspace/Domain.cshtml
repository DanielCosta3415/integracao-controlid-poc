@using Integracao.ControlID.PoC.Helpers
@model DomainLandingViewModel
@{
    ViewData["Title"] = Model.Domain.Title;
    ViewData["Subtitle"] = Model.Domain.Description;
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Domínio operacional",
        Title = Model.Domain.Title,
        Description = Model.Domain.Summary,
        BadgeText = $"{Model.Domain.Modules.Count} superfícies registradas",
        BadgeTone = Model.Domain.AccentTone,
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Mapa funcional", Href = Url.Action("Index", "Workspace")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <section class="domain-hero domain-hero--@Model.Domain.AccentTone">
        <div class="domain-hero__copy">
            <span class="app-chip app-chip--neutral">@Model.Domain.ShortTitle</span>
            <h2>@Model.Domain.Description</h2>
            <p>@Model.Domain.Summary</p>
        </div>
        <div class="domain-hero__stats">
            <div class="app-mini-stat">
                <span>Principais</span>
                <strong>@Model.PrimaryModules.Count</strong>
            </div>
            <div class="app-mini-stat">
                <span>Apoio</span>
                <strong>@Model.SecondaryModules.Count</strong>
            </div>
        </div>
    </section>

    <section class="app-surface-card app-stack domain-section domain-section--primary">
        <div class="app-page-section__heading">
            <div>
                    <strong>Módulos principais</strong>
                    <p>Estas entradas merecem o acesso mais rápido durante a operação diária da PoC.</p>
            </div>
            <span class="app-chip app-chip--neutral">@Model.PrimaryModules.Count recomendados</span>
        </div>

        <div class="module-grid">
            @foreach (var module in Model.PrimaryModules)
            {
                var experienceLabel = NavigationPresentationHelper.GetExperienceLabel(module.ExperienceType);
                var actionLabel = NavigationPresentationHelper.GetActionLabel(module);
                var helperText = NavigationPresentationHelper.GetModuleHint(module);
                <article class="module-card module-card--primary">
                    <div class="module-card__meta">
                        <span class="app-chip app-chip--@Model.Domain.AccentTone">@module.Complexity</span>
                        <span class="app-chip app-chip--success">@experienceLabel</span>
                    </div>
                    <div class="module-card__body">
                        <h3>@module.Label</h3>
                        <p>@module.Description</p>
                        <small class="module-card__hint">@helperText</small>
                    </div>
                    <div class="module-card__footer">
                        <a class="btn btn-primary btn-sm module-card__cta"
                           href="@Url.Action(module.Action, module.Controller)"
                           aria-label="@($"{actionLabel} {module.Label}")">
                            @actionLabel
                        </a>
                    </div>
                </article>
            }
        </div>
    </section>

    @if (Model.SecondaryModules.Any())
    {
        <section class="app-surface-card app-stack domain-section domain-section--secondary">
            <div class="app-page-section__heading">
                <div>
                    <strong>Áreas especializadas e de apoio</strong>
                    <p>Estas superfícies continuam disponíveis para qualidade, diagnóstico e operação avançada, sem ocupar o primeiro nível da navegação principal.</p>
                </div>
                <span class="app-chip app-chip--neutral">@Model.SecondaryModules.Count superfícies de apoio</span>
            </div>

            <div class="module-directory-grid">
                @foreach (var module in Model.SecondaryModules)
                {
                    var experienceLabel = NavigationPresentationHelper.GetExperienceLabel(module.ExperienceType);
                    var actionLabel = NavigationPresentationHelper.GetActionLabel(module, isSecondary: true);
                    var helperText = NavigationPresentationHelper.GetModuleHint(module);
                    <article class="module-directory-card module-directory-card--secondary">
                        <div class="module-directory-card__meta">
                            <span class="app-chip app-chip--neutral">@module.Complexity</span>
                            <span class="app-chip app-chip--neutral">@experienceLabel</span>
                        </div>
                        <div class="module-directory-card__body">
                            <h3>@module.Label</h3>
                            <p>@module.Description</p>
                            <small class="module-card__hint">@helperText</small>
                        </div>
                        <div class="module-directory-card__footer">
                            <a class="btn btn-outline-secondary btn-sm module-directory-card__cta"
                               href="@Url.Action(module.Action, module.Controller)"
                               aria-label="@($"{actionLabel} {module.Label}")">
                                @actionLabel
                            </a>
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</div>
