@model Integracao.ControlID.PoC.ViewModels.Groups.GroupEditViewModel
@{
    ViewData["Title"] = "Editar Grupo";
}

<div class="container mt-5">
    <h2>Editar Grupo</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post" autocomplete="off">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <p class="text-muted small">
                    Esta edição trabalha apenas com os campos confirmados para o objeto oficial `groups`.
                </p>
                <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
