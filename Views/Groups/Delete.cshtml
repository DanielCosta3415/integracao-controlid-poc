@model Integracao.ControlID.PoC.ViewModels.Groups.GroupDeleteViewModel
@{
    ViewData["Title"] = "Excluir grupo";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Excluir grupo",
        Description = "Revise o grupo selecionado antes de confirmar a exclusão desse registro oficial da base local da PoC.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar para grupos", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <section class="detail-card detail-card--danger app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>ID</span><strong>@Model.Id</strong></div>
            <div class="entity-overview__item"><span>Nome</span><strong>@Model.Name</strong></div>
        </div>
        <div class="app-note">A exclusão pode afetar vínculos com regras e credenciais já cadastradas. Confirme antes de prosseguir.</div>
    </section>

    <section class="app-surface-card app-stack">
        <div class="alert alert-warning mb-0">
            Deseja realmente excluir o grupo <strong>@Model.Name</strong>?
        </div>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions">
            <button type="submit" class="btn btn-danger">Sim, excluir grupo</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </section>
</div>
