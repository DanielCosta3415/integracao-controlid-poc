@model Integracao.ControlID.PoC.ViewModels.System.SystemNetworkViewModel
@{
    ViewData["Title"] = "Rede do equipamento";
    ViewData["Subtitle"] = "Parâmetros oficiais de rede, hostname e SSL em uma visão operacional mais clara.";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Infraestrutura",
        Title = "Rede e SSL",
        Description = "Gerencie IP, máscara, gateway, DNS, hostname, porta web e o certificado SSL oficial sem misturar configuração de rede com o restante do sistema.",
        BadgeText = "Infraestrutura oficial",
        BadgeTone = "danger",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "OpenVPN", Href = Url.Action("Vpn")!, ButtonClass = "btn btn-outline-secondary" },
            new PageHeaderActionViewModel { Label = "Voltar para sistema", Href = Url.Action("Info")!, ButtonClass = "btn btn-primary" }
        }
    };
    var responsePanel = string.IsNullOrWhiteSpace(Model.LastResponseJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Última resposta técnica",
            Description = "Payload bruto retornado pelas chamadas oficiais de rede/SSL realizadas pela PoC.",
            Content = Model.LastResponseJson,
            PanelId = "system-network-response",
            BadgeText = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "Retorno técnico" : Model.ResultStatusType,
            BadgeTone = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "neutral" : Model.ResultStatusType,
            StartExpanded = false
        };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">
            @Model.ResultMessage
        </div>
    }

    <section class="detail-card app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>Endereço IP</span><strong>@Model.IpAddress</strong></div>
            <div class="entity-overview__item"><span>Gateway</span><strong>@Model.Gateway</strong></div>
            <div class="entity-overview__item"><span>Porta web</span><strong>@Model.WebServerPort</strong></div>
            <div class="entity-overview__item"><span>SSL</span><strong>@(Model.SslEnabled ? "Habilitado" : "Desabilitado")</strong></div>
        </div>
    </section>

    <section class="app-grid-two app-grid-two--main">
        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Configuração de rede</strong>
                    <p>Ajuste IP, máscara, gateway, DNS, hostname e porta web em um único payload operacional.</p>
                </div>
            </div>

            <form asp-action="Network" method="post" autocomplete="off" class="form-section">
                <div class="app-form-grid">
                    <div>
                        <label asp-for="IpAddress" class="form-label"></label>
                        <input asp-for="IpAddress" class="form-control" />
                        <span asp-validation-for="IpAddress" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Netmask" class="form-label"></label>
                        <input asp-for="Netmask" class="form-control" />
                        <span asp-validation-for="Netmask" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Gateway" class="form-label"></label>
                        <input asp-for="Gateway" class="form-control" />
                        <span asp-validation-for="Gateway" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="WebServerPort" class="form-label"></label>
                        <input asp-for="WebServerPort" class="form-control" />
                        <span asp-validation-for="WebServerPort" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="DnsPrimary" class="form-label"></label>
                        <input asp-for="DnsPrimary" class="form-control" />
                        <span asp-validation-for="DnsPrimary" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="DnsSecondary" class="form-label"></label>
                        <input asp-for="DnsSecondary" class="form-control" />
                        <span asp-validation-for="DnsSecondary" class="text-danger"></span>
                    </div>
                    <div class="app-form-grid--full app-form-grid">
                        <div class="form-check">
                            <input asp-for="CustomHostnameEnabled" class="form-check-input" />
                            <label asp-for="CustomHostnameEnabled" class="form-check-label"></label>
                        </div>
                        <div class="form-check">
                            <input asp-for="SslEnabled" class="form-check-input" />
                            <label asp-for="SslEnabled" class="form-check-label"></label>
                        </div>
                        <div class="form-check">
                            <input asp-for="SelfSignedCertificate" class="form-check-input" />
                            <label asp-for="SelfSignedCertificate" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="app-form-grid--full">
                        <label asp-for="DeviceHostname" class="form-label"></label>
                        <input asp-for="DeviceHostname" class="form-control" />
                        <span asp-validation-for="DeviceHostname" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Aplicar rede</button>
                    <a asp-action="Info" class="btn btn-quiet">Cancelar</a>
                </div>
            </form>
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Certificado SSL</strong>
                    <p>Envie um arquivo PEM, CRT ou CER para substituir o certificado do servidor web do equipamento.</p>
                </div>
            </div>

            <form asp-action="UploadSslCertificate" method="post" enctype="multipart/form-data" autocomplete="off" class="form-section">
                <input asp-for="IpAddress" type="hidden" />
                <input asp-for="Netmask" type="hidden" />
                <input asp-for="Gateway" type="hidden" />
                <input asp-for="CustomHostnameEnabled" type="hidden" />
                <input asp-for="DeviceHostname" type="hidden" />
                <input asp-for="WebServerPort" type="hidden" />
                <input asp-for="SslEnabled" type="hidden" />
                <input asp-for="SelfSignedCertificate" type="hidden" />
                <input asp-for="DnsPrimary" type="hidden" />
                <input asp-for="DnsSecondary" type="hidden" />

                <div class="app-upload-field">
                    <label asp-for="CertificateFile" class="form-label"></label>
                    <input asp-for="CertificateFile" class="form-control" type="file" accept=".pem,.crt,.cer" />
                    <p class="app-upload-field__hint">Envie um certificado PEM, CRT ou CER pronto para uso no servidor web do equipamento.</p>
                    <div class="app-upload-field__meta">
                        <span class="product-specific-token">Formatos: PEM, CRT, CER</span>
                        <span class="product-specific-token">Fluxo: upload de certificado</span>
                    </div>
                    <span asp-validation-for="CertificateFile" class="text-danger"></span>
                </div>

                <div class="app-note">
                    O certificado enviado será aplicado ao servidor web oficial do equipamento. Use este fluxo em conjunto com SSL habilitado para validar o ambiente final.
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-outline-secondary">Enviar certificado</button>
                </div>
            </form>
        </section>
    </section>

    @if (responsePanel != null)
    {
        <partial name="_RawResponsePanel" model="responsePanel" />
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
