@model Integracao.ControlID.PoC.ViewModels.System.SystemVpnViewModel
@{
    ViewData["Title"] = "OpenVPN";
    ViewData["Subtitle"] = "Configuração, upload do arquivo oficial e leitura do estado atual da VPN do equipamento.";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Infraestrutura",
        Title = "OpenVPN",
        Description = "Centralize configuração, credenciais e arquivos da VPN oficial em uma trilha única, separando leitura de estado e alteração operacional.",
        BadgeText = "Acesso remoto",
        BadgeTone = "warning",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Baixar exemplo", Href = Url.Action("DownloadVpnFile")!, ButtonClass = "btn btn-outline-secondary" },
            new PageHeaderActionViewModel { Label = "Voltar para rede", Href = Url.Action("Network")!, ButtonClass = "btn btn-primary" }
        }
    };
    var responsePanel = string.IsNullOrWhiteSpace(Model.LastResponseJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Última resposta técnica",
            Description = "Payload bruto retornado pelas chamadas oficiais de VPN executadas pela PoC.",
            Content = Model.LastResponseJson,
            PanelId = "system-vpn-response",
            BadgeText = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "Retorno técnico" : Model.ResultStatusType,
            BadgeTone = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "neutral" : Model.ResultStatusType
        };
    var informationPanel = string.IsNullOrWhiteSpace(Model.InformationJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Configuração atual",
            Description = "JSON bruto retornado pelo endpoint oficial de configuração da VPN.",
            Content = Model.InformationJson,
            PanelId = "system-vpn-information",
            BadgeText = "Informação",
            BadgeTone = "neutral"
        };
    var statusPanel = string.IsNullOrWhiteSpace(Model.StatusJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Status atual",
            Description = "JSON bruto retornado pelo endpoint oficial de status da VPN.",
            Content = Model.StatusJson,
            PanelId = "system-vpn-status",
            BadgeText = "Status",
            BadgeTone = "success"
        };
    var filePanel = string.IsNullOrWhiteSpace(Model.FileStatusJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Presença de arquivo",
            Description = "JSON bruto retornado pela verificação do arquivo de configuração da VPN.",
            Content = Model.FileStatusJson,
            PanelId = "system-vpn-file-status",
            BadgeText = "Arquivo",
            BadgeTone = "warning"
        };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="alert alert-@(TempData["StatusType"] ?? "info")">@statusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">
            @Model.ResultMessage
        </div>
    }

    <section class="detail-card app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>VPN habilitada</span><strong>@(Model.Enabled ? "Sim" : "Não")</strong></div>
            <div class="entity-overview__item"><span>Login manual</span><strong>@(Model.LoginEnabled ? "Sim" : "Não")</strong></div>
            <div class="entity-overview__item"><span>Arquivo presente</span><strong>@(Model.HasFile.HasValue ? (Model.HasFile.Value ? "Sim" : "Não") : "Indefinido")</strong></div>
            <div class="entity-overview__item"><span>Status</span><strong>@(Model.StatusCode.HasValue ? $"{Model.StatusDescription} ({Model.StatusCode})" : "Indefinido")</strong></div>
        </div>
    </section>

    <section class="app-grid-two app-grid-two--main">
        <div class="app-stack">
            <section class="app-surface-card app-stack">
                <div class="app-page-section__heading">
                    <div>
                        <strong>Configuração da VPN</strong>
                        <p>Ative a VPN, habilite login manual quando necessário e mantenha as credenciais oficiais em um fluxo separado do upload de arquivo.</p>
                    </div>
                </div>

                <form asp-action="Vpn" method="post" autocomplete="off" class="form-section">
                    <div class="app-form-grid">
                        <div class="form-check">
                            <input asp-for="Enabled" class="form-check-input" />
                            <label asp-for="Enabled" class="form-check-label"></label>
                        </div>
                        <div class="form-check">
                            <input asp-for="LoginEnabled" class="form-check-input" />
                            <label asp-for="LoginEnabled" class="form-check-label"></label>
                        </div>
                        <div>
                            <label asp-for="Login" class="form-label"></label>
                            <input asp-for="Login" class="form-control" />
                        </div>
                        <div>
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" type="password" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Salvar configuração</button>
                    </div>
                </form>
            </section>

            <section class="app-surface-card app-stack">
                <div class="app-page-section__heading">
                    <div>
                        <strong>Arquivo de configuração</strong>
                        <p>Envie o arquivo oficial da VPN para o equipamento mantendo o restante do estado sincronizado com os campos atuais.</p>
                    </div>
                </div>

                <form asp-action="UploadVpnFile" method="post" enctype="multipart/form-data" autocomplete="off" class="form-section">
                    <input asp-for="Enabled" type="hidden" />
                    <input asp-for="LoginEnabled" type="hidden" />
                    <input asp-for="Login" type="hidden" />
                    <input asp-for="Password" type="hidden" />

                    <div>
                        <label asp-for="VpnFile" class="form-label"></label>
                        <input asp-for="VpnFile" class="form-control" type="file" accept=".conf,.zip" />
                        <span asp-validation-for="VpnFile" class="text-danger"></span>
                    </div>

                    <div class="app-note">
                        Use este fluxo quando o arquivo oficial da VPN já estiver pronto. O painel técnico abaixo ajuda a validar se o equipamento reconheceu o arquivo enviado.
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-outline-secondary">Enviar arquivo VPN</button>
                    </div>
                </form>
            </section>
        </div>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Leitura operacional</strong>
                    <p>Resumo rápido do que a PoC conhece sobre o estado atual da VPN antes de qualquer alteração.</p>
                </div>
            </div>

            <div class="app-note">Combine o resumo desta coluna com os painéis técnicos abaixo para validar configuração, status do túnel e presença do arquivo oficial.</div>

            <div class="entity-overview">
                <div class="entity-overview__item"><span>Configuração</span><strong>@(string.IsNullOrWhiteSpace(Model.InformationJson) ? "Indisponível" : "Carregada")</strong></div>
                <div class="entity-overview__item"><span>Status</span><strong>@(string.IsNullOrWhiteSpace(Model.StatusJson) ? "Indisponível" : "Carregado")</strong></div>
                <div class="entity-overview__item"><span>Arquivo</span><strong>@(string.IsNullOrWhiteSpace(Model.FileStatusJson) ? "Indisponível" : "Carregado")</strong></div>
            </div>
        </section>
    </section>

    @if (responsePanel != null)
    {
        <partial name="_RawResponsePanel" model="responsePanel" />
    }

    @if (informationPanel != null)
    {
        <partial name="_RawResponsePanel" model="informationPanel" />
    }

    @if (statusPanel != null)
    {
        <partial name="_RawResponsePanel" model="statusPanel" />
    }

    @if (filePanel != null)
    {
        <partial name="_RawResponsePanel" model="filePanel" />
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
