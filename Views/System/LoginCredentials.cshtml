@model Integracao.ControlID.PoC.ViewModels.System.SystemLoginCredentialsViewModel
@{
    ViewData["Title"] = "Credenciais do equipamento";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Infraestrutura",
        Title = "Credenciais de login do equipamento",
        Description = "Atualize o usuário e a senha usados no login oficial do equipamento, mantendo a resposta técnica visível para auditoria.",
        BadgeText = "Ação administrativa",
        BadgeTone = "warning",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar para sistema", Href = Url.Action("Info")!, ButtonClass = "btn btn-outline-secondary" },
            new PageHeaderActionViewModel { Label = "Gerar hash", Href = Url.Action("HashPassword")!, ButtonClass = "btn btn-primary" }
        }
    };
    var responsePanel = string.IsNullOrWhiteSpace(Model.ResponseJson)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Resposta oficial",
            Description = "JSON bruto retornado pela alteração das credenciais de login do equipamento.",
            Content = Model.ResponseJson,
            PanelId = "system-login-credentials-response",
            BadgeText = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "Retorno técnico" : Model.ResultStatusType,
            BadgeTone = string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "neutral" : Model.ResultStatusType,
            StartExpanded = true
        };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">@Model.ResultMessage</div>
    }

    <section class="detail-card app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>Fluxo</span><strong>change_login_credentials</strong></div>
            <div class="entity-overview__item"><span>Escopo</span><strong>Login do equipamento</strong></div>
        </div>
        <div class="app-note">Use esta tela somente quando o objetivo for alterar as credenciais do próprio equipamento. Para hashes de usuário final, use o fluxo específico de hash.</div>
    </section>

    <section class="app-grid-two app-grid-two--main">
        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Atualizar credenciais</strong>
                    <p>Informe o novo usuário e a nova senha que passarão a ser usados pela trilha oficial de autenticação.</p>
                </div>
            </div>

            <form asp-action="LoginCredentials" method="post" autocomplete="off" class="form-section">
                <div class="app-form-grid">
                    <div>
                        <label asp-for="Login" class="form-label"></label>
                        <input asp-for="Login" class="form-control" />
                        <span asp-validation-for="Login" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-warning">Alterar credenciais</button>
                </div>
            </form>
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Orientação operacional</strong>
                    <p>Antes de aplicar a mudança, confirme se a equipe responsável já validou o novo acesso e se a PoC não depende das credenciais antigas em outras sessões abertas.</p>
                </div>
            </div>

            <div class="app-note">Depois da alteração, o ideal é validar o login pela tela de autenticação e revisar a sessão ativa usada nos demais módulos.</div>
        </section>
    </section>

    @if (responsePanel != null)
    {
        <partial name="_RawResponsePanel" model="responsePanel" />
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
