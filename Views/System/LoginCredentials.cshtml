@model Integracao.ControlID.PoC.ViewModels.System.SystemLoginCredentialsViewModel
@{
    ViewData["Title"] = "Credenciais do Equipamento";
}

<div class="container mt-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h2 class="mb-1">Credenciais de Login do Equipamento</h2>
            <p class="text-muted mb-0">Altera o usuário e a senha usados no `login.fcgi` do próprio equipamento.</p>
        </div>
        <a asp-action="Info" class="btn btn-outline-secondary">Voltar para Sistema</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ResultStatusType) ? "info" : Model.ResultStatusType)">
            @Model.ResultMessage
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="LoginCredentials" method="post" autocomplete="off">
                <div class="mb-3">
                    <label asp-for="Login" class="form-label"></label>
                    <input asp-for="Login" class="form-control" />
                    <span asp-validation-for="Login" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-warning">Alterar Credenciais</button>
                    <a asp-action="HashPassword" class="btn btn-outline-primary">Gerar Hash de Senha de Usuário</a>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ResponseJson))
            {
                <hr />
                <h5>Resposta Oficial</h5>
                <pre class="small mb-0">@Model.ResponseJson</pre>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
