@model Integracao.ControlID.PoC.ViewModels.System.HashPasswordViewModel
@{
    ViewData["Title"] = "Gerar Hash de Senha";
}

<div class="container mt-5">
    <h2>Gerar Hash de Senha</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="HashPassword" method="post" autocomplete="off">
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Gerar Hash</button>
                <a asp-action="Info" class="btn btn-secondary ms-2">Cancelar</a>
            </form>
            @if (!string.IsNullOrEmpty(Model.Hash))
            {
                <div class="mt-4 alert alert-success">
                    <strong>Hash Gerado:</strong>
                    <pre>@Model.Hash</pre>
                    @if (!string.IsNullOrEmpty(Model.Salt))
                    {
                        <strong>Salt:</strong>
                        <pre>@Model.Salt</pre>
                    }
                </div>
            }
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}