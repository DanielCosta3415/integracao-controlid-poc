@model Integracao.ControlID.PoC.ViewModels.System.HashPasswordViewModel
@{
    ViewData["Title"] = "Gerar hash de senha";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Infraestrutura",
        Title = "Gerar hash de senha",
        Description = "Gere um hash local para validações operacionais e diagnóstico, mantendo a resposta organizada em um painel técnico simples.",
        BadgeText = "Ferramenta utilitária",
        BadgeTone = "neutral",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Voltar para sistema", Href = Url.Action("Info")!, ButtonClass = "btn btn-outline-secondary" }
        }
    };
    var hashPanel = string.IsNullOrWhiteSpace(Model.Hash)
        ? null
        : new RawResponsePanelViewModel
        {
            Title = "Hash gerado",
            Description = string.IsNullOrWhiteSpace(Model.Salt) ? "Resultado do cálculo atual." : $"Salt associado: {Model.Salt}",
            Content = string.IsNullOrWhiteSpace(Model.Salt) ? Model.Hash : $"Hash:\n{Model.Hash}\n\nSalt:\n{Model.Salt}",
            PanelId = "system-hash-password-result",
            BadgeText = "Saída técnica",
            BadgeTone = "success",
            StartExpanded = true
        };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <section class="app-grid-two app-grid-two--main">
        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Entrada da senha</strong>
                    <p>Informe a senha que deve ser transformada em hash para testes, apoio operacional ou análise técnica.</p>
                </div>
            </div>

            <form asp-action="HashPassword" method="post" autocomplete="off" class="form-section">
                <div>
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Gerar hash</button>
                    <a asp-action="Info" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </section>

        <section class="app-surface-card app-stack">
            <div class="app-page-section__heading">
                <div>
                    <strong>Uso recomendado</strong>
                    <p>Prefira esta tela para diagnóstico local e comparação técnica. Não reutilize a saída em fluxos finais sem validar o contrato esperado pelo equipamento.</p>
                </div>
            </div>

            <div class="app-note">Quando um salt for retornado, copie também esse valor junto com o hash para manter a análise reproduzível.</div>
        </section>
    </section>

    @if (hashPanel != null)
    {
        <partial name="_RawResponsePanel" model="hashPanel" />
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

