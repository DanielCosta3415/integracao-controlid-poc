@model Integracao.ControlID.PoC.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Login local";
    ViewData["Subtitle"] = "Autentique-se na PoC antes de acessar operações e dados locais.";
    var returnUrl = ViewData["ReturnUrl"] as string ?? "/";
}

<div class="container mt-5">
    <div class="auth-shell">
        <section class="auth-panel auth-panel--accent">
            <span class="app-chip app-chip--danger">Acesso protegido</span>
            <h1 class="mt-3">Entre com uma conta local antes de operar a PoC.</h1>
            <p class="mt-3">
                A conta local controla o acesso à interface administrativa. A autenticação do equipamento continua separada na tela de login do dispositivo.
            </p>
            <ul>
                <li>O primeiro cadastro local se torna administrador.</li>
                <li>Novos cadastros depois do bootstrap exigem administrador autenticado.</li>
                <li>Operações de alto impacto exigem papel de administrador.</li>
            </ul>
        </section>

        <section class="auth-panel app-stack">
            <div>
                <span class="app-chip app-chip--neutral">Conta local</span>
                <h2 class="mt-3">Acessar a PoC</h2>
                <p class="mt-2 text-muted">Use o usuário local ou e-mail cadastrado na base SQLite da PoC.</p>
            </div>

            <form asp-action="LocalLogin" asp-route-returnUrl="@returnUrl" method="post" autocomplete="off" class="form-section">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div>
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" autofocus />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary w-100">Entrar na PoC</button>
                </div>
            </form>

            <div class="app-empty">
                Primeiro acesso? <a asp-action="Register">Registrar administrador local</a>.
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
