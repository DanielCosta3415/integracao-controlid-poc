@model Integracao.ControlID.PoC.ViewModels.Auth.AuthStatusViewModel
@{
    ViewData["Title"] = "Status da Autenticação";
}

<div class="container mt-5">
    <h2>Status da Autenticação</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Dispositivo</dt>
                <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.DeviceAddress) ? Model.DeviceAddress : "-")</dd>

                <dt class="col-sm-3">Sessão</dt>
                <dd class="col-sm-9"><code>@(!string.IsNullOrWhiteSpace(Model.SessionString) ? Model.SessionString : "-")</code></dd>

                <dt class="col-sm-3">Autenticado</dt>
                <dd class="col-sm-9">
                    @if (Model.IsAuthenticated)
                    {
                        <span class="badge bg-success">Sim</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Não</span>
                    }
                </dd>
            </dl>

            <a asp-action="Login" class="btn btn-primary">Entrar</a>
            <a asp-action="Logout" class="btn btn-outline-danger">Sair</a>
        </div>
    </div>
</div>
