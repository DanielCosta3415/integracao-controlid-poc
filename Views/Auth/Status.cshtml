@model Integracao.ControlID.PoC.ViewModels.Auth.AuthStatusViewModel
@{
    ViewData["Title"] = "Status da autenticação";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Status da autenticação",
        Description = "Confira se existe sessão oficial em contexto antes de seguir para endpoints que exigem autenticação ativa no equipamento.",
        BadgeText = Model.IsAuthenticated ? "Autenticado" : "Não autenticado",
        BadgeTone = Model.IsAuthenticated ? "success" : "warning",
        Actions = new[]
        {
            new PageHeaderActionViewModel { Label = "Entrar", Href = Url.Action("Login")!, ButtonClass = "btn btn-primary" }
        }
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <section class="detail-card app-stack">
        <div class="entity-overview">
            <div class="entity-overview__item"><span>Dispositivo</span><strong>@(!string.IsNullOrWhiteSpace(Model.DeviceAddress) ? Model.DeviceAddress : "Não definido")</strong></div>
            <div class="entity-overview__item"><span>Sessão</span><strong>@(!string.IsNullOrWhiteSpace(Model.SessionString) ? "Disponível" : "Ausente")</strong></div>
            <div class="entity-overview__item"><span>Autenticação</span><strong>@(Model.IsAuthenticated ? "Válida" : "Pendente")</strong></div>
        </div>
    </section>

    <section class="app-surface-card app-stack">
        <div class="app-page-section__heading">
            <div>
                <strong>Contexto oficial</strong>
                <p>Resumo direto do que a PoC conhece sobre o dispositivo e a sessão oficial salva localmente.</p>
            </div>
        </div>

        <dl class="row">
            <dt class="col-sm-3">Dispositivo</dt>
            <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.DeviceAddress) ? Model.DeviceAddress : "-")</dd>

            <dt class="col-sm-3">Sessão</dt>
            <dd class="col-sm-9"><code>@Model.MaskedSessionString</code></dd>

            <dt class="col-sm-3">Autenticado</dt>
            <dd class="col-sm-9">@(Model.IsAuthenticated ? "Sim" : "Não")</dd>
        </dl>

        <form asp-action="Logout" method="post" class="app-inline-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">Sair com segurança</button>
        </form>
    </section>
</div>
