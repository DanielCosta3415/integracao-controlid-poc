@{
    ViewData["Title"] = "Acesso negado";
    ViewData["Subtitle"] = "A ação solicitada exige permissões adicionais.";
}

<div class="container mt-5">
    <section class="app-surface-card app-stack">
        <div class="app-page-section__heading">
            <div>
                <span class="app-chip app-chip--danger">Restrito</span>
                <h1 class="mt-3">Acesso negado</h1>
                <p>Esta operação exige uma conta local autenticada com o papel necessário.</p>
            </div>
        </div>
        <div class="form-actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Voltar ao painel</a>
            <a asp-controller="Auth" asp-action="LocalLogin" class="btn btn-outline-secondary">Trocar conta</a>
        </div>
    </section>
</div>
