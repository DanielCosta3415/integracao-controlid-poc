@model Integracao.ControlID.PoC.ViewModels.Auth.ChangePasswordViewModel
@{
    ViewData["Title"] = "Alterar senha";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Alterar senha local",
        Description = "Atualize a senha de um usuário local da PoC informando o identificador da conta e a credencial atual para validação.",
        BadgeText = "Conta local",
        BadgeTone = "neutral"
    };
}

<div class="container mt-5 app-stack">
    <partial name="_AppPageHeader" model="header" />

    <div class="row justify-content-center">
        <div class="col-lg-6 col-xl-5">
            <section class="app-surface-card app-stack">
                <div class="app-page-section__heading">
                    <div>
                        <strong>Atualizar credencial local</strong>
                        <p>Informe o usuário local e valide a senha atual antes de registrar a nova combinação no banco local da PoC.</p>
                    </div>
                </div>

                <form asp-action="ChangePassword" method="post" autocomplete="off" class="form-section">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div>
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="CurrentPassword" class="form-label"></label>
                        <input asp-for="CurrentPassword" class="form-control" type="password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" class="form-control" type="password" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-warning">Alterar senha</button>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
