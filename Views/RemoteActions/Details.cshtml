@model Integracao.ControlID.PoC.ViewModels.RemoteActions.RemoteActionViewModel
@{
    ViewData["Title"] = "Detalhes da ação remota";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Operação",
        Title = "Detalhes da ação remota",
        Description = "Consulte o resumo da ação remota, seus parâmetros e o resultado atual antes de disparar novas execuções.",
        BadgeText = "Consulta",
        BadgeTone = "neutral",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para ações remotas", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>Ação</span><strong>@Model.Action</strong></div><div class="entity-overview__item"><span>Exibição</span><strong>@Model.DisplayName</strong></div><div class="entity-overview__item"><span>Resultado</span><strong>@(string.IsNullOrWhiteSpace(Model.Result) ? "Não informado" : Model.Result)</strong></div></div></section><section class="app-surface-card app-stack"><div class="app-page-section__heading"><div><strong>Resumo da ação</strong><p>Visualize os parâmetros atuais e o resultado registrado para essa ação remota.</p></div></div><dl class="row"><dt class="col-sm-3">Ação</dt><dd class="col-sm-9">@Model.Action</dd><dt class="col-sm-3">Exibição</dt><dd class="col-sm-9">@Model.DisplayName</dd><dt class="col-sm-3">Parâmetros</dt><dd class="col-sm-9">@Model.Parameters</dd><dt class="col-sm-3">Resultado</dt><dd class="col-sm-9">@Model.Result</dd></dl></section></div>
