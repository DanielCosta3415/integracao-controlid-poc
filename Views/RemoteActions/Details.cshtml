@model Integracao.ControlID.PoC.ViewModels.RemoteActions.RemoteActionViewModel
@{
    ViewData["Title"] = "Detalhes da Ação Remota";
}

<div class="container mt-5">
    <h2>Detalhes da Ação Remota</h2>
    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Ação</dt>
                <dd class="col-sm-9">@Model.Action</dd>
                <dt class="col-sm-3">Exibição</dt>
                <dd class="col-sm-9">@Model.DisplayName</dd>
                <dt class="col-sm-3">Parâmetros</dt>
                <dd class="col-sm-9">@Model.Parameters</dd>
                <dt class="col-sm-3">Resultado</dt>
                <dd class="col-sm-9">@Model.Result</dd>
            </dl>
            <a asp-action="Index" class="btn btn-secondary">Voltar</a>
        </div>
    </div>
</div>