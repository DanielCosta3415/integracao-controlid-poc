@model Integracao.ControlID.PoC.ViewModels.Logo.LogoDeleteViewModel
@{
    ViewData["Title"] = "Excluir logo";
    var header = new AppPageHeaderViewModel
    {
        Eyebrow = "Pessoas",
        Title = "Excluir logo",
        Description = "Revise o slot e o arquivo selecionados antes de remover o logo do equipamento.",
        BadgeText = "Zona de risco",
        BadgeTone = "danger",
        Actions = new[] { new PageHeaderActionViewModel { Label = "Voltar para logos", Href = Url.Action("Index")!, ButtonClass = "btn btn-outline-secondary" } }
    };
}
<div class="container mt-5 app-stack"><partial name="_AppPageHeader" model="header" /><section class="detail-card detail-card--danger app-stack"><div class="entity-overview"><div class="entity-overview__item"><span>Slot</span><strong>@Model.Id</strong></div><div class="entity-overview__item"><span>Arquivo</span><strong>@Model.FileName</strong></div></div><div class="app-note">A exclusão remove o logo institucional do slot indicado e pode alterar a experiência visual do equipamento.</div></section><section class="app-surface-card app-stack"><div class="alert alert-warning mb-0">Deseja realmente excluir o logo <strong>@Model.FileName</strong> do slot <strong>@Model.Id</strong>?</div><form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions">@Html.AntiForgeryToken()<button type="submit" class="btn btn-danger">Sim, excluir logo</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></section></div>
